<Application x:Class="D4BuildFilter.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:D4BuildFilter.WPF"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Tokens FIRST: the theme-invariant design system (radius/type/elevation/spacing/
                     font/motion). No ThemeId sentinel, so ThemeManager never unmerges it on a swap. -->
                <ResourceDictionary Source="/Themes/Tokens.xaml" />
                <!-- v1.0.4: original class emblems (theme-invariant vector art; no ThemeId sentinel,
                     so ThemeManager leaves it merged across theme swaps). -->
                <ResourceDictionary Source="/Assets/ClassEmblems.xaml" />
                <ResourceDictionary Source="/Assets/ClassCrests.xaml" />
                <!-- v1.0.5: licensed class icons (game-icons.net, CC BY 3.0; credit line lives in
                     the footer). Preferred by NameToEmblemConverter; emblems remain the fallback. -->
                <ResourceDictionary Source="/Assets/ClassIcons.xaml" />
                <!-- Default theme. ThemeManager swaps THIS for Discord/Dark at runtime
                     based on %LOCALAPPDATA%\MedicKsMight\theme.json. -->
                <ResourceDictionary Source="/Themes/Default.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
