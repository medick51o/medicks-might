<UserControl x:Class="D4BuildFilter.WPF.WitnessCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:D4BuildFilter.WPF"
             Width="1200" Height="675" Background="#0A090C">
    <UserControl.Resources>
        <local:NameToCrestConverter x:Key="NameToCrest" />
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="pack://application:,,,/Assets/Fonts/#Inter, Segoe UI" />
            <Setter Property="Foreground" Value="#F1EAE2" />
        </Style>
    </UserControl.Resources>
    <!-- The Witness Card is intentionally self-contained: fixed pixels, fixed palette, and only
         original MK/class-crest art, so themes and CC BY icon licensing cannot leak into a share. -->
    <Border Background="#0A090C" BorderBrush="#6E5120" BorderThickness="2" Padding="54,46,54,34">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Margin="0,2,20,0">
                    <ItemsControl ItemsSource="{Binding Builds}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,18,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <ContentControl Width="82" Height="82"
                                                    Content="{Binding ClassName, Converter={StaticResource NameToCrest}}" />
                                    <StackPanel Grid.Column="1" Margin="20,4,0,0">
                                        <TextBlock Text="{Binding ClassName}" FontSize="17" FontWeight="SemiBold"
                                                   Foreground="{Binding ClassColorHex}" TextOptions.TextFormattingMode="Display" />
                                        <TextBlock Text="{Binding BuildName}" FontSize="34" FontWeight="ExtraBold"
                                                   TextTrimming="CharacterEllipsis" TextOptions.TextFormattingMode="Display" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Background="#342A1F" BorderBrush="#80612C" BorderThickness="1" CornerRadius="13"
                            Padding="11,4" HorizontalAlignment="Left" Margin="0,7,0,0">
                        <TextBlock Text="{Binding ProvenanceChip, TargetNullValue=Community build}" FontSize="15" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Image Source="/Assets/mk_logo.png" Width="64" Height="64" HorizontalAlignment="Right" />
                    <TextBlock Text="MEDICK'S MIGHT" FontSize="15" FontWeight="ExtraBold" Foreground="#D4AF37" Margin="0,7,0,0" />
                </StackPanel>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding LegendRows}" Margin="0,28,0,22">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#17141A" BorderBrush="#383039" BorderThickness="1" CornerRadius="8"
                                Padding="10,7" Margin="0,0,10,9">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="13" Height="13" Fill="{Binding ColorHex}" Margin="0,1,8,0" />
                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="2" Background="#111015" BorderBrush="#3C343D" BorderThickness="1" CornerRadius="10" Padding="20,14">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="DIABLO 4 IMPORT CODE" FontSize="12" FontWeight="Bold" Foreground="#A99D91" />
                        <TextBlock Text="{Binding RuleCountLabel}" FontSize="13" FontWeight="SemiBold" Foreground="#D4AF37"
                                   HorizontalAlignment="Right" />
                    </DockPanel>
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,10,0,0">
                        <TextBlock Text="{Binding ImportCode}" Width="1080" FontFamily="Consolas" FontSize="13"
                                   Foreground="#D8D1CB" TextWrapping="Wrap" LineHeight="16" />
                    </Viewbox>
                </Grid>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,20,0,0">
                <TextBlock DockPanel.Dock="Right" Text="{Binding VersionStamp}" FontSize="13" Foreground="#8F857D" />
                <TextBlock FontSize="14" Foreground="#BDB1A8"><Run Text="JOIN THE CREW  "/><Run Text="{Binding DiscordInvite}" Foreground="#D4AF37" FontWeight="SemiBold" /></TextBlock>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
