<!--
    Tokens.xaml  -  the SHARED DESIGN SYSTEM (geometry + type + elevation + motion primitives).

    Theme-INVARIANT on purpose: merged ahead of the active Themes/{Default,Dark,Discord}.xaml in
    App.xaml and carries NO ThemeId sentinel, so ThemeManager.Apply() never unmerges it on a swap.
    Colors live in the theme dicts; SHAPE / RHYTHM / TYPE / ELEVATION / MOTION live here.

    These map 1:1 to the CSS custom properties in web/style.css (the space, radius and text vars) so
    the future web port inherits the exact same design language. Desktop and web become one product.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Spacing scale (8px grid). Double-typed for widths/heights; margins/padding snap to these. -->
    <sys:Double x:Key="Space.1">4</sys:Double>
    <sys:Double x:Key="Space.2">8</sys:Double>
    <sys:Double x:Key="Space.3">12</sys:Double>
    <sys:Double x:Key="Space.4">16</sys:Double>
    <sys:Double x:Key="Space.6">24</sys:Double>
    <sys:Double x:Key="Space.8">32</sys:Double>
    <sys:Double x:Key="Space.12">48</sys:Double>

    <!-- Common uniform paddings as Thickness (the cases that recur) -->
    <Thickness x:Key="Pad.Card">16</Thickness>
    <Thickness x:Key="Pad.Control">16,8</Thickness>
    <Thickness x:Key="Pad.Chip">12,6</Thickness>

    <!-- Radius scale: exactly THREE values (was 3/4/6/9/10 scattered). control 6 / card 10 / pill. -->
    <CornerRadius x:Key="Radius.Control">6</CornerRadius>
    <CornerRadius x:Key="Radius.Card">10</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">999</CornerRadius>

    <!-- Type ramp. One web-grade font family token (Phase 3 repoints Font.Sans to Inter; until then
         it is Segoe UI so Phase 1 is a zero-visual change). Mono stays for the import code. -->
    <!-- Bundled Inter (Assets/Fonts/*.ttf, Resource). Fallback to Segoe UI if it ever fails to load. -->
    <FontFamily x:Key="Font.Sans">pack://application:,,,/Assets/Fonts/#Inter, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas</FontFamily>

    <!-- Sizes: nine 1px-apart sizes collapsed to six deliberate steps. -->
    <sys:Double x:Key="Type.Display">32</sys:Double>
    <sys:Double x:Key="Type.H1">24</sys:Double>
    <sys:Double x:Key="Type.H2">18</sys:Double>
    <!-- v1.0.5: BodyLg fills the 14→18 gap — data that should lead (badge letters, chip names). -->
    <sys:Double x:Key="Type.BodyLg">16</sys:Double>
    <sys:Double x:Key="Type.Body">14</sys:Double>
    <sys:Double x:Key="Type.BodySm">12</sys:Double>
    <sys:Double x:Key="Type.Caption">11</sys:Double>
    <sys:Double x:Key="Type.Mono">13</sys:Double>

    <!-- Elevation: whisper-light web-style card shadows (pure black, low opacity, straight down).
         Only ever applied to TRUE cards, never inset fields / swatches / the page. -->
    <DropShadowEffect x:Key="Elevation.Card" Color="#000000" BlurRadius="16" ShadowDepth="2"
                      Direction="270" Opacity="0.35" RenderingBias="Performance" />
    <DropShadowEffect x:Key="Elevation.Raised" Color="#000000" BlurRadius="24" ShadowDepth="3"
                      Direction="270" Opacity="0.45" RenderingBias="Performance" />

    <!-- Motion: standard durations so app + web agree (web transition is .14s ease-out). -->
    <sys:Double x:Key="Motion.FastMs">120</sys:Double>
    <sys:Double x:Key="Motion.CardMs">140</sys:Double>

</ResourceDictionary>
