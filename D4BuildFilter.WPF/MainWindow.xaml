<Window x:Class="D4BuildFilter.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D4BuildFilter.WPF"
        xmlns:vm="clr-namespace:D4BuildFilter.WPF.ViewModels"
        mc:Ignorable="d"
        Title="D4 Build Filter — maxroll build → in-game loot filter"
        Height="920" Width="1160"
        MinHeight="640" MinWidth="860"
        Background="#17120f">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <!-- Primary action button — D4 crimson -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#9c2b25" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b8352e" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3a3330" />
                    <Setter Property="Foreground" Value="#8a7e74" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3a312b" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a3f37" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#241d18" />
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="BorderBrush" Value="#5a4a3e" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="CaretBrush" Value="#e3d8cc" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#241d18" />
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="BorderBrush" Value="#4a3c30" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#d4af37" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════ HEADER ════════════════════════ -->
        <Border Grid.Row="0" Background="#231a14" Padding="16,12" CornerRadius="4" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="D4 Build Filter"
                           FontSize="22" FontWeight="Bold" Foreground="#d4af37" />
                <TextBlock Text="Turn a maxroll build into a ready-to-import Diablo 4 loot filter"
                           FontSize="12" Foreground="#9a8c80" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════ BODY ════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- ─── INPUT STATE ─── -->
            <Grid Visibility="{Binding IsInputState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="660">

                    <!-- Source toggle: maxroll URL vs. paste from any guide -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Button Content="maxroll URL" Command="{Binding UseUrlModeCommand}" Width="150" Height="34">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUrlMode}" Value="True">
                                            <Setter Property="Background" Value="#9c2b25" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Paste affixes" Command="{Binding UsePasteModeCommand}" Width="150" Height="34" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasteMode}" Value="True">
                                            <Setter Property="Background" Value="#9c2b25" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- URL mode -->
                    <StackPanel Visibility="{Binding IsUrlMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste a maxroll, mobalytics, or d4builds build URL"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="maxroll.gg/d4/planner/…  ·  mobalytics.gg/diablo-4/builds/…  ·  d4builds.gg/builds/…"
                                   FontSize="11" Foreground="#9a8c80" HorizontalAlignment="Center" Margin="0,0,0,16" />
                        <TextBox Text="{Binding MaxrollUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="34" FontSize="13" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Compile Filter"
                                    Command="{Binding CompileCommand}"
                                    Width="200" Height="44" FontSize="14" Margin="0,0,12,0" />
                            <Button Content="Load sample build (offline)"
                                    Command="{Binding LoadSampleCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="220" Height="44" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Paste mode (universal: any build guide) -->
                    <StackPanel Visibility="{Binding IsPasteMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste an affix list from any build guide"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="One affix per line (or comma-separated); include unique item names. Works with d4builds, Mobalytics, Icy Veins, Discord…"
                                   FontSize="11" Foreground="#9a8c80" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" Margin="0,0,0,12" />
                        <TextBox Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="200" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <Button Content="Compile from paste"
                                Command="{Binding CompilePasteCommand}"
                                Width="220" Height="44" FontSize="14"
                                HorizontalAlignment="Center" Margin="0,16,0,0" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#e0915a"
                               HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="12"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" />
                </StackPanel>
            </Grid>

            <!-- ─── LOADING STATE ─── -->
            <Grid Visibility="{Binding IsLoadingState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Compiling filter…" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#9a8c80"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ─── RESULT STATE ─── -->
            <ScrollViewer Visibility="{Binding IsResultState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding BuildName}"
                               FontSize="22" FontWeight="Bold" Foreground="#d4af37" />
                    <TextBlock Text="{Binding BuildSubtitle}"
                               FontSize="12" Foreground="#b6a597" Margin="0,4,0,12" />

                    <!-- Variant picker — uncheck a variant to drop it from the combined pool -->
                    <Border Background="#231a14" BorderBrush="#4a3c30" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Variants included (uncheck to narrow the filter — recompiles live)"
                                       Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding Variants}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  Content="{Binding Label}"
                                                  Margin="0,2,22,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: affix pool + drops -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Filterable affixes — these drive the gold / silver match"
                                       Style="{StaticResource SectionLabel}" />
                            <ListBox ItemsSource="{Binding PoolLines}" Height="240" />

                            <TextBlock Text="Not yet filterable (needs in-game ID capture)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4"
                                       Visibility="{Binding HasDropped, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding DroppedLines}" Height="120"
                                     Visibility="{Binding HasDropped, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <!-- Right: uniques + color legend -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Build uniques → purple"
                                       Style="{StaticResource SectionLabel}"
                                       Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding UniquePurpleLines}" Height="80"
                                     Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="Uniques pending capture (resolved by name, no filter ID yet)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4"
                                       Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding UniquePendingLines}" Height="80"
                                     Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="Mythics — own category, left untouched (natural beam)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4"
                                       Foreground="#ff6ec7"
                                       Visibility="{Binding HasMythics, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding MythicLines}" Height="80"
                                     Visibility="{Binding HasMythics, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="What the colors mean (top rule wins)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4" />
                            <Border Background="#241d18" BorderBrush="#4a3c30" BorderThickness="1"
                                    CornerRadius="4" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Margin="0,1"><Run Foreground="#a020f0" Text="● Purple" /><Run Text="  — your build's uniques" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#ffd700" Text="● Gold" /><Run Text="  — rare/legendary with 3+ build affixes" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#aaaaaa" Text="● Silver" /><Run Text="  — rare/legendary with 2+ build affixes" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#ff8c00" Text="● Orange" /><Run Foreground="#00ffff" Text=" / Cyan" /><Run Text="  — high item power (900 / 850)" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#2251e8" Text="● Blue" /><Run Text="  — Greater Affix items" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#00c800" Text="● Green" /><Run Text="  — Charms &amp; Seals" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#ffffff" Text="● White" /><Run Text="  — Codex of Power upgrades" /></TextBlock>
                                    <TextBlock Margin="0,1" Foreground="#9a8c80"><Run Text="◌ Hidden" /><Run Text="  — everything else (mythics still drop untouched)" /></TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Filter options — toggles recompile the code live -->
                    <TextBlock Text="Filter options" Style="{StaticResource SectionLabel}" Margin="0,16,0,4" />
                    <Border Background="#231a14" BorderBrush="#4a3c30" BorderThickness="1"
                            CornerRadius="4" Padding="14,10">
                        <StackPanel>
                            <UniformGrid Columns="2">
                                <CheckBox Content="Precise per-slot rules (recommended)" IsChecked="{Binding OptPerSlot}" Margin="0,3,14,3" />
                                <CheckBox Content="Strict endgame (Ancestral only)" IsChecked="{Binding StrictEndgame}" Margin="0,3,14,3" />
                                <CheckBox Content="Build uniques → purple" IsChecked="{Binding OptBuildUniques}" Margin="0,3,14,3" />
                                <CheckBox Content="Silver tier (2+ affixes)" IsChecked="{Binding OptSilverTier}" Margin="0,3,14,3" />
                                <CheckBox Content="Item-power tiers (900 / 850)" IsChecked="{Binding OptItemPowerTiers}" Margin="0,3,14,3" />
                                <CheckBox Content="Greater Affixes → blue" IsChecked="{Binding OptGreaterAffixes}" Margin="0,3,14,3" />
                                <CheckBox Content="Charms &amp; Seals → green" IsChecked="{Binding OptCharmsSeals}" Margin="0,3,14,3" />
                                <CheckBox Content="Codex upgrades → white" IsChecked="{Binding OptCodex}" Margin="0,3,14,3" />
                                <CheckBox Content="Hide everything else" IsChecked="{Binding OptHideRest}" Margin="0,3,14,3" />
                            </UniformGrid>
                            <TextBlock TextWrapping="Wrap" Foreground="#9a8c80" FontSize="11" Margin="0,8,0,0">
                                <Run Text="Gold tier (3+ build affixes) is always on · Mythics are never touched." /><LineBreak />
                                <Run Text="⚠ Heads-up on D4's filter limits: without " /><Run FontStyle="Italic" Text="Precise per-slot rules" /><Run Text=", the filter matches by affix COUNT across ALL slots — so an item can show a false 'keep' if it rolled enough of the build's affixes that actually belong on OTHER slots (e.g. boots that rolled chest/ring stats). Per-slot rules scope each rule to its item type to remove that (at the cost of more rules). With Silver tier, expect more borderline highlights." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Filter title — becomes the filter's name in-game when imported -->
                    <TextBlock Text="Filter title (your branding — the name Diablo 4 shows on import)"
                               Style="{StaticResource SectionLabel}" Margin="0,16,0,4" />
                    <TextBox Text="{Binding FilterTitle, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="24" Height="32" FontSize="13" FontFamily="Segoe UI" />
                    <TextBlock Text="{Binding TitleLengthNote}" FontSize="11" Margin="0,3,0,0" Foreground="#9a8c80" />

                    <!-- Import code -->
                    <TextBlock Text="Import code" Style="{StaticResource SectionLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding ImportCode, Mode=OneWay}"
                             IsReadOnly="True" Height="120" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontSize="11" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="📋 Copy import code"
                                Command="{Binding CopyCodeCommand}"
                                Width="200" Height="40" />
                        <TextBlock Text="{Binding FilterInfo}" Foreground="#b6a597"
                                   VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" FontFamily="Consolas" />
                    </StackPanel>

                    <!-- How to import -->
                    <Border Background="#231a14" BorderBrush="#5a4a3e" BorderThickness="1"
                            CornerRadius="4" Padding="14,12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="How to import into Diablo 4" FontWeight="Bold" FontSize="13"
                                       Foreground="#d4af37" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#cdbfb2" LineHeight="20">
                                <Run Text="1. In Diablo 4, open the Character menu and go to the Loot Filter tab." /><LineBreak />
                                <Run Text="2. Click Import / Export, then Import." /><LineBreak />
                                <Run Text="3. Paste the code above and confirm. The filter applies immediately." /><LineBreak />
                                <Run Text="Filters sync across platforms through your Battle.net account (25-rule cap; rules apply top-down, first match wins)." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="← Compile another build"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="220" Height="44" FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- ════════════════════════ FOOTER ════════════════════════ -->
        <Border Grid.Row="2" Background="#231a14" Padding="12,6" CornerRadius="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="11" Foreground="#7a6e64" VerticalAlignment="Center">
                    <Run Text="D4 Build Filter (preview)" />
                    <Run Text="  •  " />
                    <Run Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#8c8" />
                </TextBlock>

                <TextBlock Grid.Column="2" FontSize="10" Foreground="#5a504a" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    Free community tool. Not affiliated with Blizzard or maxroll.gg.
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
