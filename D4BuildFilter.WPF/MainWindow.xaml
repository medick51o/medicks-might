<Window x:Class="D4BuildFilter.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D4BuildFilter.WPF"
        xmlns:vm="clr-namespace:D4BuildFilter.WPF.ViewModels"
        mc:Ignorable="d"
        Title="MedicK's Might (BETA) — Filters Made EZ"
        Icon="Assets/mk_logo.png"
        Height="920" Width="1160"
        MinHeight="640" MinWidth="860"
        Background="#17120f">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ActiveColorConverter x:Key="ActiveColor" />
        <local:ActiveTextConverter x:Key="ActiveText" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <!-- Primary action button — D4 crimson -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#9c2b25" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b8352e" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3a3330" />
                    <Setter Property="Foreground" Value="#8a7e74" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3a312b" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a3f37" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#241d18" />
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="BorderBrush" Value="#5a4a3e" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="CaretBrush" Value="#e3d8cc" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#241d18" />
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="BorderBrush" Value="#4a3c30" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e3d8cc" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#d4af37" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Clickable build "chip" used in the tier lists. Semi-transparent so the landing-page
             hero background bleeds through (the chip still reads clearly against the dimmed art). -->
        <Style x:Key="BuildChip" TargetType="Button">
            <Setter Property="Background" Value="#402A221C" />
            <Setter Property="Foreground" Value="#d8cabb" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#803C2F25" />
                                <Setter Property="Foreground" Value="#f0d6a8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tier-list source tab (Endgame / Bossing / Leveling / Push / Speedfarm etc).
             Active state pulled from the TierTabVM.IsActive property — gold-on-dark when selected,
             dim-cream-on-transparent otherwise. -->
        <Style x:Key="TierTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9a8c80" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="tabBg" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}" BorderBrush="#3a312b" BorderThickness="1">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBg" Property="Background" Value="#2A221C" />
                                <Setter Property="Foreground" Value="#c8b59a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#3a2a1c" />
                    <Setter Property="Foreground" Value="#d4af37" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Small text link button ("view full list ↗") -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9fb6d8" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#cfe0f5" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════ HEADER (banner shown ONCE WORKING; landing has the art as
             a full-bleed BACKGROUND behind translucent tier cards instead — see Grid.Row="1") ═══ -->

        <!-- WORKING BANNER: slim 260px crop (UniformToFill) shown during loading + result. The same
             art, but trimmed so the build screen has room to drive. -->
        <Border Grid.Row="0" Height="260" CornerRadius="4" Margin="0,0,0,12"
                ClipToBounds="True" Background="#17120f"
                Visibility="{Binding IsNotInputState, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Image Source="Assets/hero.jpg" Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0.00" Color="#00000000" />
                            <GradientStop Offset="0.55" Color="#80000000" />
                            <GradientStop Offset="1.00" Color="#FF17120F" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="22,0,22,16">
                    <Image Source="Assets/mk_logo.png" Width="56" Height="56" VerticalAlignment="Center"
                           Margin="0,0,16,0" RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="30" FontWeight="Bold">
                                <Run Text="M" Foreground="#e22d24" /><Run Text="edic" Foreground="#d4af37" /><Run Text="K" Foreground="#e22d24" /><Run Text="'s Might" Foreground="#d4af37" />
                            </TextBlock>
                            <TextBlock Text="Filters Made EZ" VerticalAlignment="Bottom" Margin="14,0,0,5"
                                       FontSize="14" FontStyle="Italic" FontWeight="SemiBold" Foreground="#f5b86b" />
                        </StackPanel>
                        <TextBlock Text="Turn any Diablo 4 build into a ready-to-import loot filter"
                                   FontSize="13" Foreground="#e3d8cc" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════ BODY ════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- LANDING BACKGROUND: the warlord art behind the input + tier-list content, dimmed so
                 the gold/red UI reads cleanly. Tier cards on top are semi-transparent so the art
                 bleeds through. Only on the input state — the build screen stays clean. -->
            <Image Source="Assets/hero.jpg" Stretch="UniformToFill" Opacity="0.55"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Visibility="{Binding IsInputState, Converter={StaticResource BoolToVis}}" />

            <!-- ─── INPUT STATE ─── -->
            <ScrollViewer x:Name="InputScroll"
                          Visibility="{Binding IsInputState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <!-- InputColumn.Width is pinned to the ScrollViewer viewport in code-behind, so the
                   WrapPanels wrap against a finite width and centering works (a plain Disabled
                   ScrollViewer otherwise sizes its content to the widest tier row). -->
              <Grid>
                <StackPanel x:Name="InputColumn" HorizontalAlignment="Left" Margin="0,4,0,16">

                <!-- ══════ Landing brand header — MK + title + manifesto slogan ══════ -->
                <StackPanel HorizontalAlignment="Center" Margin="0,20,0,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="Assets/mk_logo.png" Width="68" Height="68" VerticalAlignment="Center"
                               Margin="0,0,18,0" RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="34" FontWeight="Bold">
                                    <Run Text="M" Foreground="#e22d24" /><Run Text="edic" Foreground="#d4af37" /><Run Text="K" Foreground="#e22d24" /><Run Text="'s Might" Foreground="#d4af37" />
                                </TextBlock>
                                <TextBlock Text="Filters Made EZ" VerticalAlignment="Bottom" Margin="14,0,0,6"
                                           FontSize="15" FontStyle="Italic" FontWeight="SemiBold" Foreground="#f5b86b" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="THE GOLD STANDARD IN LOOT FILTER STANDARDIZATION FOR DIABLO 4"
                               HorizontalAlignment="Center" Margin="0,10,0,0"
                               FontSize="13" FontWeight="Bold" Foreground="#d4af37"
                               TextAlignment="Center" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" MaxWidth="660" Margin="0,16,0,0">

                    <!-- Source toggle: maxroll URL vs. paste from any guide -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Button Content="maxroll URL" Command="{Binding UseUrlModeCommand}" Width="150" Height="34">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUrlMode}" Value="True">
                                            <Setter Property="Background" Value="#9c2b25" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Paste affixes" Command="{Binding UsePasteModeCommand}" Width="150" Height="34" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasteMode}" Value="True">
                                            <Setter Property="Background" Value="#9c2b25" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- URL mode -->
                    <StackPanel Visibility="{Binding IsUrlMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste a maxroll, mobalytics, or d4builds build URL"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="maxroll.gg/d4/planner/…  ·  mobalytics.gg/diablo-4/builds/…  ·  d4builds.gg/builds/…"
                                   FontSize="11" Foreground="#9a8c80" HorizontalAlignment="Center" Margin="0,0,0,16"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBox Text="{Binding MaxrollUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="34" FontSize="13" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Compile Filter"
                                    Command="{Binding CompileCommand}"
                                    Width="200" Height="44" FontSize="14" Margin="0,0,12,0" />
                            <Button Content="Load sample build (offline)"
                                    Command="{Binding LoadSampleCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="220" Height="44" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Paste mode (universal: any build guide) -->
                    <StackPanel Visibility="{Binding IsPasteMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste an affix list from any build guide"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="One affix per line (or comma-separated); include unique item names. Works with d4builds, Mobalytics, Icy Veins, Discord…"
                                   FontSize="11" Foreground="#9a8c80" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" Margin="0,0,0,12" />
                        <TextBox Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="200" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <Button Content="Compile from paste"
                                Command="{Binding CompilePasteCommand}"
                                Width="220" Height="44" FontSize="14"
                                HorizontalAlignment="Center" Margin="0,16,0,0" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#e0915a"
                               HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="12"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" />
                </StackPanel>

                <!-- ══════ This season's top builds — live community tier lists ══════
                     Three columns: D4Builds (left), Maxroll (middle), Mobalytics (right).
                     Every tier surfaced: S/A/B/C/D plus Mobalytics-only God Tier (top) and Support
                     (utility). Cards + chips at 25% opacity so the warlord background bleeds through. -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,30,0,0">
                    <TextBlock Text="This season's top builds" FontSize="18" FontWeight="Bold"
                               Foreground="#d4af37" HorizontalAlignment="Center" />
                    <TextBlock Text="Pulled live from the community. Click any build to load it straight into the filter."
                               FontSize="11" Foreground="#9a8c80" HorizontalAlignment="Center" Margin="0,2,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- ── D4Builds (col 0) ── -->
                        <Border Grid.Column="0" Background="#401D1611" BorderBrush="#4a3c30" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,5,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding D4BuildsTierUrl}" />
                                    <TextBlock Text="D4Builds" FontSize="16" FontWeight="Bold" Foreground="#d4af37"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding D4BuildsTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectD4BuildsTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding D4BuildsTierStatus}" Foreground="#b6a597" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding D4BuildsTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding D4BuildsTiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="4"
                                                        MinWidth="30" Height="26" VerticalAlignment="Top" Padding="6,0"
                                                        HorizontalAlignment="Center" Margin="0,1,4,0">
                                                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#1a1410" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                                                    Foreground="{Binding ClassColor}"
                                                                    Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Maxroll (col 1) ── -->
                        <Border Grid.Column="1" Background="#401D1611" BorderBrush="#4a3c30" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="5,0,5,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding MaxrollTierUrl}" />
                                    <TextBlock Text="Maxroll" FontSize="16" FontWeight="Bold" Foreground="#d4af37"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MaxrollTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectMaxrollTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MaxrollTierStatus}" Foreground="#b6a597" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding MaxrollTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding MaxrollTiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="4"
                                                        MinWidth="30" Height="26" VerticalAlignment="Top" Padding="6,0"
                                                        HorizontalAlignment="Center" Margin="0,1,4,0">
                                                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#1a1410" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                                                    Foreground="{Binding ClassColor}"
                                                                    Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Mobalytics (col 2, NEW) ── God + S/A/B/C + Support -->
                        <Border Grid.Column="2" Background="#401D1611" BorderBrush="#4a3c30" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="5,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding MobalyticsTierUrl}" />
                                    <TextBlock Text="Mobalytics" FontSize="16" FontWeight="Bold" Foreground="#d4af37"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MobalyticsTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectMobalyticsTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MobalyticsTierStatus}" Foreground="#b6a597" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding MobalyticsTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding MobalyticsTiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="4"
                                                        MinWidth="30" Height="26" VerticalAlignment="Top" Padding="6,0"
                                                        HorizontalAlignment="Center" Margin="0,1,4,0">
                                                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#1a1410" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                                                    Foreground="{Binding ClassColor}"
                                                                    Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="Tier lists belong to Maxroll.gg, D4Builds.gg, and Mobalytics.gg respectively — shown here with attribution."
                               FontSize="10" Foreground="#6b625a" HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
                </StackPanel>
              </Grid>
            </ScrollViewer>

            <!-- ─── LOADING STATE ─── -->
            <Grid Visibility="{Binding IsLoadingState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Compiling filter…" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#9a8c80"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ─── RESULT STATE ─── -->
            <ScrollViewer Visibility="{Binding IsResultState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding BuildName}"
                               FontSize="22" FontWeight="Bold" Foreground="#d4af37" />
                    <TextBlock Text="{Binding BuildSubtitle}"
                               FontSize="12" Foreground="#b6a597" Margin="0,4,0,12" />

                    <!-- Variant picker — uncheck a variant to drop it from the combined pool -->
                    <Border Background="#231a14" BorderBrush="#4a3c30" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Variants included (uncheck to narrow the filter — recompiles live)"
                                       Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding Variants}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  Content="{Binding Label}"
                                                  Margin="0,2,22,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: affix pool + drops -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Filterable affixes — these drive the gold / silver match"
                                       Style="{StaticResource SectionLabel}" />
                            <ListBox ItemsSource="{Binding PoolLines}" Height="240" />

                            <TextBlock Text="Not yet filterable (needs in-game ID capture)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4"
                                       Visibility="{Binding HasDropped, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding DroppedLines}" Height="120"
                                     Visibility="{Binding HasDropped, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <!-- Right: uniques + color legend -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Build uniques → purple"
                                       Style="{StaticResource SectionLabel}"
                                       Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding UniquePurpleLines}" Height="80"
                                     Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="Uniques pending capture (resolved by name, no filter ID yet)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4"
                                       Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding UniquePendingLines}" Height="80"
                                     Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="Mythics — own category, left untouched (natural beam)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4"
                                       Foreground="#ff6ec7"
                                       Visibility="{Binding HasMythics, Converter={StaticResource BoolToVis}}" />
                            <ListBox ItemsSource="{Binding MythicLines}" Height="80"
                                     Visibility="{Binding HasMythics, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="What the colors mean (top rule wins)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4" />
                            <Border Background="#241d18" BorderBrush="#4a3c30" BorderThickness="1"
                                    CornerRadius="4" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Margin="0,1"><Run Foreground="#a020f0" Text="● Purple" /><Run Text="  — your build's uniques" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#ffd700" Text="● Gold" /><Run Text="  — rare/legendary with 3+ build affixes" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#aaaaaa" Text="● Silver" /><Run Text="  — rare/legendary with 2+ build affixes" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#ff8c00" Text="● Orange" /><Run Foreground="#00ffff" Text=" / Cyan" /><Run Text="  — high item power (900 / 850)" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#2251e8" Text="● Blue" /><Run Text="  — Greater Affix items" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#00c800" Text="● Green" /><Run Text="  — Charms &amp; Seals" /></TextBlock>
                                    <TextBlock Margin="0,1"><Run Foreground="#ffffff" Text="● White" /><Run Text="  — Codex of Power upgrades" /></TextBlock>
                                    <TextBlock Margin="0,1" Foreground="#9a8c80"><Run Text="◌ Hidden" /><Run Text="  — everything else (mythics still drop untouched)" /></TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Filter options — toggles recompile the code live -->
                    <TextBlock Text="Filter options" Style="{StaticResource SectionLabel}" Margin="0,16,0,4" />
                    <Border Background="#231a14" BorderBrush="#4a3c30" BorderThickness="1"
                            CornerRadius="4" Padding="14,12">
                        <StackPanel>
                            <!-- ── Primary matching choice: per-slot mode + the two color-coded build-affix tiers ── -->
                            <CheckBox Content="Precise per-slot rules (recommended)" IsChecked="{Binding OptPerSlot}"
                                      Foreground="{Binding OptPerSlot, Converter={StaticResource ActiveText}}" Margin="0,0,0,8" />
                            <TextBlock Text="Build-affix tiers — how many of a slot's affixes an item needs, and the color it gets:"
                                       FontSize="11" Foreground="#9a8c80" Margin="0,0,0,6" />
                            <UniformGrid Columns="2">
                                <!-- 3+ → Gold -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptGoldTier, Converter={StaticResource ActiveColor}, ConverterParameter=#FFD700}" />
                                    <CheckBox Content="3+ affixes per slot → Gold (best items)" IsChecked="{Binding OptGoldTier}"
                                              Foreground="{Binding OptGoldTier, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- 2+ → Silver -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptSilverTier, Converter={StaticResource ActiveColor}, ConverterParameter=#AAAAAA}" />
                                    <CheckBox Content="2+ affixes per slot → Silver (one roll away)" IsChecked="{Binding OptSilverTier}"
                                              Foreground="{Binding OptSilverTier, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                            </UniformGrid>

                            <Border Height="1" Background="#3a312b" Margin="0,10,0,10" />

                            <!-- ── Secondary tiers (each marker shows its in-game highlight color, grays when off) ── -->
                            <UniformGrid Columns="2">
                                <!-- Build uniques → purple -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptBuildUniques, Converter={StaticResource ActiveColor}, ConverterParameter=#A020F0}" />
                                    <CheckBox Content="Build uniques → Purple" IsChecked="{Binding OptBuildUniques}"
                                              Foreground="{Binding OptBuildUniques, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- Greater Affixes → blue -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptGreaterAffixes, Converter={StaticResource ActiveColor}, ConverterParameter=#2251E8}" />
                                    <CheckBox Content="Greater Affixes → Blue" IsChecked="{Binding OptGreaterAffixes}"
                                              Foreground="{Binding OptGreaterAffixes, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- Item-power tiers → orange / cyan -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,3,0"
                                            Background="{Binding OptItemPowerTiers, Converter={StaticResource ActiveColor}, ConverterParameter=#FF8C00}" />
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptItemPowerTiers, Converter={StaticResource ActiveColor}, ConverterParameter=#00FFFF}" />
                                    <CheckBox Content="Item power 900/850 → Orange/Cyan (gearing aid — noisy at endgame)" IsChecked="{Binding OptItemPowerTiers}"
                                              Foreground="{Binding OptItemPowerTiers, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- Charms &amp; Seals → green -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptCharmsSeals, Converter={StaticResource ActiveColor}, ConverterParameter=#00C800}" />
                                    <CheckBox Content="Charms &amp; Seals → Green" IsChecked="{Binding OptCharmsSeals}"
                                              Foreground="{Binding OptCharmsSeals, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- Codex upgrades → white -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="{Binding OptCodex, Converter={StaticResource ActiveColor}, ConverterParameter=#FFFFFF}" />
                                    <CheckBox Content="Codex upgrades → White" IsChecked="{Binding OptCodex}"
                                              Foreground="{Binding OptCodex, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- Hide everything else → no highlight (hollow marker) -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                            Background="Transparent" BorderBrush="#6b625a" BorderThickness="1" />
                                    <CheckBox Content="Hide everything else" IsChecked="{Binding OptHideRest}"
                                              Foreground="{Binding OptHideRest, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                                <!-- Strict endgame → behavioral (no highlight color) -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,14,2">
                                    <Border Width="13" Height="13" Margin="0,0,7,0" Background="Transparent" />
                                    <CheckBox Content="Strict endgame (Ancestral only)" IsChecked="{Binding StrictEndgame}"
                                              Foreground="{Binding StrictEndgame, Converter={StaticResource ActiveText}}" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock TextWrapping="Wrap" Foreground="#9a8c80" FontSize="11" Margin="0,10,0,0">
                                <Run Text="Each gear slot gets its own rule, scoped to that item type — so a boots rule only ever matches boots. Gold = great keepers, Silver = one roll away (it sits below Gold, so a 3+ item still goes Gold). Mythics are never touched." /><LineBreak />
                                <Run Text="⚠ Turning OFF " /><Run FontStyle="Italic" Text="Precise per-slot rules" /><Run Text=" falls back to matching by affix COUNT across ALL slots, which can show false 'keeps' (e.g. boots that rolled chest/ring stats)." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Filter title — becomes the filter's name in-game when imported -->
                    <TextBlock Text="Filter title (your branding — the name Diablo 4 shows on import)"
                               Style="{StaticResource SectionLabel}" Margin="0,16,0,4" />
                    <TextBox Text="{Binding FilterTitle, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="24" Height="32" FontSize="13" FontFamily="Segoe UI" />
                    <TextBlock Text="{Binding TitleLengthNote}" FontSize="11" Margin="0,3,0,0" Foreground="#9a8c80" />

                    <!-- Import code -->
                    <TextBlock Text="Import code" Style="{StaticResource SectionLabel}" Margin="0,12,0,4" />
                    <TextBox Text="{Binding ImportCode, Mode=OneWay}"
                             IsReadOnly="True" Height="120" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontSize="11" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="📋 Copy import code"
                                Command="{Binding CopyCodeCommand}"
                                Width="200" Height="40" />
                        <TextBlock Text="{Binding FilterInfo}" Foreground="#b6a597"
                                   VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" FontFamily="Consolas" />
                    </StackPanel>

                    <!-- Rule-cap warning: D4 rejects filters over 25 rules on import -->
                    <Border Background="#3a1414" BorderBrush="#d0524a" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding HasCapWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding CapWarning}" TextWrapping="Wrap" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#f3b0ab" />
                    </Border>

                    <!-- Re-import warning: options regenerate the code; an imported filter won't auto-update -->
                    <Border Background="#3a2a14" BorderBrush="#e0915a" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,10,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#f0c89a">
                            <Run FontWeight="Bold" Text="⚠ Changed an option (e.g. toggled a Gold/Silver tier)?" />
                            <Run Text=" The code above is rebuilt every time you toggle something — but a filter you've ALREADY pasted into Diablo 4 won't update on its own. To apply a change: copy the new code and import it again, or check/uncheck the matching rules directly in the in-game filter." />
                        </TextBlock>
                    </Border>

                    <!-- How to import -->
                    <Border Background="#231a14" BorderBrush="#5a4a3e" BorderThickness="1"
                            CornerRadius="4" Padding="14,12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="How to import into Diablo 4" FontWeight="Bold" FontSize="13"
                                       Foreground="#d4af37" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#cdbfb2" LineHeight="20">
                                <Run Text="1. In Diablo 4, open the Character menu and go to the Loot Filter tab." /><LineBreak />
                                <Run Text="2. Click Import / Export, then Import." /><LineBreak />
                                <Run Text="3. Paste the code above and confirm. The filter applies immediately." /><LineBreak />
                                <Run Text="Filters sync across platforms through your Battle.net account (25-rule cap; rules apply top-down, first match wins)." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="← Compile another build"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="220" Height="44" FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- ════════════════════════ FOOTER ════════════════════════ -->
        <Border Grid.Row="2" Background="#231a14" Padding="12,6" CornerRadius="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="11" Foreground="#7a6e64" VerticalAlignment="Center">
                    <Run Text="D4 Build Filter (preview)" />
                    <Run Text="  •  " />
                    <Run Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#8c8" />
                </TextBlock>

                <TextBlock Grid.Column="2" FontSize="10" Foreground="#5a504a" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    Free community tool. Not affiliated with Blizzard or maxroll.gg.
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
