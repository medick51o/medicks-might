<Window x:Class="D4BuildFilter.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D4BuildFilter.WPF"
        xmlns:vm="clr-namespace:D4BuildFilter.WPF.ViewModels"
        mc:Ignorable="d"
        Title="MedicK's Might (BETA) — Filters Made EZ"
        Icon="Assets/mk_logo.png"
        Height="920" Width="1160"
        MinHeight="640" MinWidth="860"
        Background="{DynamicResource Surface.Page}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ActiveColorConverter x:Key="ActiveColor" />
        <local:ActiveTextConverter x:Key="ActiveText" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <local:FavoriteStarConverter x:Key="FavStar" />
        <local:FavoriteStarBrushConverter x:Key="FavStarBrush" />
        <local:AllTrueToVisibilityConverter x:Key="AllTrueToVis" />
        <local:SourceToBrushConverter x:Key="SourceBrush" />
        <local:StringEqualsConverter x:Key="StrEq" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <!-- Primary action button — themed via Action.Primary tokens -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
            <Setter Property="Foreground" Value="{DynamicResource Action.Primary.Fg}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg.Hover}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource Action.Disabled.Bg}" />
                    <Setter Property="Foreground" Value="{DynamicResource Action.Disabled.Fg}" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource Action.Secondary.Bg}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Action.Secondary.Bg.Hover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Surface.Inset}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Input}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="CaretBrush" Value="{DynamicResource Text.Primary}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Surface.Inset}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Strong}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Clickable build "chip" used in the tier lists. Semi-transparent so the landing-page
             hero background bleeds through (the chip still reads clearly against the dimmed art). -->
        <Style x:Key="BuildChip" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Surface.Card}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <!-- Two-line content: build name (TemplateBinding Content, set per
                                 instance) then an optional "(ClassName)" subtitle bound to the
                                 chip's DataContext (TierBuildVM.ClassName). Subtitle Visibility is
                                 driven by MainViewModel.ShowClassNames so the toggle on the landing
                                 page collapses every chip's class line at once. -->
                            <StackPanel>
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Foreground="{TemplateBinding Foreground}"
                                           Opacity="0.7" FontSize="10"
                                           TextAlignment="Center" HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding DataContext.ShowClassNames,
                                                        RelativeSource={RelativeSource AncestorType=Window},
                                                        Converter={StaticResource BoolToVis}}">
                                    <Run Text="(" /><Run Text="{Binding ClassName, Mode=OneWay}" /><Run Text=")" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tiny star button overlaid on a chip's top-right corner. Click toggles favorited state
             on the chip's VM; rest of the chip area stays clickable for Load (the star Button only
             captures clicks within its small footprint, the chip Button beneath gets the rest). -->
        <Style x:Key="FavStarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tier-list source tab (Endgame / Bossing / Leveling / Push / Speedfarm etc).
             Active state pulled from the TierTabVM.IsActive property — gold-on-dark when selected,
             dim-cream-on-transparent otherwise. -->
        <Style x:Key="TierTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Muted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="tabBg" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource Border.Subtle}" BorderThickness="1">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBg" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                    <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Small text link button ("view full list ↗") -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Accent.Link}" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Accent.Link.Hover}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════ HEADER: slim 56px chrome, always visible across all states.
             Replaced the old 260px working banner with a slim wordmark + state indicator so the
             working screens (Result/Options/Loading) recover ~200px of vertical real estate. The
             landing's centered brand callout still sits inside the input column for hero treatment;
             this slim bar is the persistent chrome that anchors every state. ════════════════════ -->
        <Border Grid.Row="0" Height="56" Background="{DynamicResource Surface.Header}" Margin="0,0,0,10"
                BorderBrush="{DynamicResource Border.Subtle}" BorderThickness="0,0,0,1" CornerRadius="0">
            <DockPanel LastChildFill="True" Margin="18,0">
                <!-- Right: theme picker gear → opens popup with 3 radio options + brand-color swatches.
                     beta.8.5: ThemeManager swaps the active Themes/*.xaml dictionary live; choice
                     persists to %LOCALAPPDATA%\MedicKsMight\theme.json. -->
                <Button x:Name="ThemePickerAnchor" DockPanel.Dock="Right"
                        Command="{Binding ToggleThemePickerCommand}"
                        Background="Transparent" BorderThickness="0" Padding="8,2"
                        VerticalAlignment="Center" Cursor="Hand"
                        Width="38" Height="38" Margin="6,0,0,0"
                        ToolTip="Pick a theme — Default / Discord / Dark">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="gb" Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="⚙" FontSize="22"
                                           Foreground="{DynamicResource Accent.Primary}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="gb" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Popup IsOpen="{Binding IsThemePickerOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=ThemePickerAnchor}" Placement="Bottom"
                       HorizontalOffset="-200" VerticalOffset="6" AllowsTransparency="True">
                    <Border Background="{DynamicResource Surface.Panel}"
                            BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12" MinWidth="240">
                        <StackPanel>
                            <TextBlock Text="Theme" Style="{StaticResource SectionLabel}" Margin="0,0,0,8" />
                            <!-- Each row = a brand swatch + a radio. Two-way StrEq binding makes the
                                 radio reflect SelectedTheme and set it on click. SelectedTheme's setter
                                 hooks into ThemeManager.Apply via the partial OnSelectedThemeChanged. -->
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0"
                                        Background="#d4af37" VerticalAlignment="Center" />
                                <RadioButton GroupName="ThemePicker" Content="Default — Warlord gold + crimson"
                                             Foreground="{DynamicResource Text.Primary}"
                                             VerticalContentAlignment="Center"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource StrEq}, ConverterParameter=Default}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0"
                                        Background="#5865f2" VerticalAlignment="Center" />
                                <RadioButton GroupName="ThemePicker" Content="Discord — blurple greys"
                                             Foreground="{DynamicResource Text.Primary}"
                                             VerticalContentAlignment="Center"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource StrEq}, ConverterParameter=Discord}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0"
                                        Background="#22d3ee" VerticalAlignment="Center" />
                                <RadioButton GroupName="ThemePicker" Content="Dark — true black + cyan"
                                             Foreground="{DynamicResource Text.Primary}"
                                             VerticalContentAlignment="Center"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource StrEq}, ConverterParameter=Dark}" />
                            </StackPanel>
                            <!-- Theme-agnostic toggle: when ON, ThemeManager forces Surface.Panel
                                 + Surface.Inset opacity to ~65% so the warlord watermark surfaces
                                 through cards/inputs. Applies on top of any theme; re-applies on
                                 theme swap (so a Default→Discord switch keeps the translucency). -->
                            <Border Background="{DynamicResource Border.Subtle}" Height="1" Margin="0,10,0,8" />
                            <CheckBox IsChecked="{Binding TranslucentPanels}"
                                      Content="Translucent panels"
                                      Foreground="{DynamicResource Text.Primary}"
                                      ToolTip="Adds transparency to the panel backgrounds." />
                            <TextBlock Text="Persists across launches"
                                       FontSize="10" Foreground="{DynamicResource Text.Muted}"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </Popup>
                <!-- Build name on the right of the build-name area, before the gear -->
                <TextBlock DockPanel.Dock="Right" Text="{Binding BuildName}"
                           VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Primary}" TextTrimming="CharacterEllipsis"
                           Margin="0,0,12,0"
                           Visibility="{Binding IsResultState, Converter={StaticResource BoolToVis}}" />
                <!-- Left: MK monogram + wordmark + slogan -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/mk_logo.png" Width="36" Height="36"
                           Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" />
                    <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="M" Foreground="{DynamicResource Accent.Secondary}" /><Run Text="edic" Foreground="{DynamicResource Accent.Primary}" /><Run Text="K" Foreground="{DynamicResource Accent.Secondary}" /><Run Text="'s Might" Foreground="{DynamicResource Accent.Primary}" />
                    </TextBlock>
                    <TextBlock Text="Filters Made EZ" VerticalAlignment="Center" Margin="10,0,0,0"
                               FontSize="12" FontStyle="Italic" FontWeight="SemiBold" Foreground="{DynamicResource Text.Secondary}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════ BODY ════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- FULL-PAGE WATERMARK: warlord art behind all content across every state, dimmed to
                 22% so the gold/crimson UI reads cleanly on Result/Options too. IsHitTestVisible=
                 False so it never intercepts clicks. Was landing-only at 55%; promoted in beta.8 to
                 unify the brand presence across screens (per design review). -->
            <Image Source="Assets/hero.jpg" Stretch="UniformToFill" Opacity="{DynamicResource Watermark.Opacity}"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   IsHitTestVisible="False" />

            <!-- ─── INPUT STATE ─── -->
            <ScrollViewer x:Name="InputScroll"
                          Visibility="{Binding IsInputState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <!-- InputColumn.Width is pinned to the ScrollViewer viewport in code-behind, so the
                   WrapPanels wrap against a finite width and centering works (a plain Disabled
                   ScrollViewer otherwise sizes its content to the widest tier row). -->
              <Grid>
                <StackPanel x:Name="InputColumn" HorizontalAlignment="Left" Margin="0,4,0,16">

                <!-- ══════ Landing manifesto + tagline ══════
                     The MK monogram + wordmark already sits in the slim 56px chrome above; this
                     callout is just the value-prop tagline + manifesto, so the landing keeps its
                     hero feeling without burning 220px of vertical on a redundant logo lockup. -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,4">
                    <TextBlock Text="Turn any Diablo 4 build into a ready-to-import loot filter"
                               HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Primary}" />
                    <TextBlock Text="THE GOLD STANDARD IN LOOT FILTER STANDARDIZATION FOR DIABLO 4"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                               TextAlignment="Center" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" MaxWidth="660" Margin="0,16,0,0">

                    <!-- Source toggle: maxroll URL vs. paste from any guide -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Button Content="maxroll URL" Command="{Binding UseUrlModeCommand}" Width="150" Height="34">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUrlMode}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Paste affixes" Command="{Binding UsePasteModeCommand}" Width="150" Height="34" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasteMode}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- URL mode -->
                    <StackPanel Visibility="{Binding IsUrlMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste a maxroll, mobalytics, or d4builds build URL"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="maxroll.gg/d4/planner/…  ·  mobalytics.gg/diablo-4/builds/…  ·  d4builds.gg/builds/…"
                                   FontSize="11" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center" Margin="0,0,0,16"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBox Text="{Binding MaxrollUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="34" FontSize="13" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Compile Filter"
                                    Command="{Binding CompileCommand}"
                                    Width="200" Height="44" FontSize="14" Margin="0,0,12,0" />
                            <Button Content="Load sample build (offline)"
                                    Command="{Binding LoadSampleCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="220" Height="44" FontSize="13" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Paste mode (universal: any build guide) -->
                    <StackPanel Visibility="{Binding IsPasteMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste an affix list from any build guide"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="One affix per line (or comma-separated); include unique item names. Works with d4builds, Mobalytics, Icy Veins, Discord…"
                                   FontSize="11" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" Margin="0,0,0,12" />
                        <TextBox Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="200" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <Button Content="Compile from paste"
                                Command="{Binding CompilePasteCommand}"
                                Width="220" Height="44" FontSize="14"
                                HorizontalAlignment="Center" Margin="0,16,0,0" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Caution.Fg}"
                               HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="12"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" />
                </StackPanel>

                <!-- ══════ Your Saved Builds ══════
                     Persisted starred builds from %LOCALAPPDATA%\MedicKsMight\favorites.json.
                     Each chip is a LIVE REFERENCE — clicking re-fetches the build from its source so
                     the player gets THIS month's meta, not what was current when they starred it.
                     beta.8: header now shows count + empty state, so first-run users see the affordance
                     instead of an invisible feature (was hidden behind HasFavorites). -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,24,0,0">
                    <DockPanel LastChildFill="True" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding FavoritesCountLabel}"
                                   FontSize="11" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center">
                            <Run Text="★ Your saved builds" />
                        </TextBlock>
                    </DockPanel>
                    <!-- Empty state — visible when zero favorites; replaces the (previously hidden) chip rail. -->
                    <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Subtle}" BorderThickness="1"
                            CornerRadius="6" Padding="14,10"
                            Visibility="{Binding HasNoFavorites, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Star any build below to pin it here. Picks are live — clicking re-fetches the latest version from its source."
                                   FontSize="11" Foreground="{DynamicResource Text.Muted}" TextWrapping="Wrap" />
                    </Border>
                    <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12"
                            Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Favorites}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Two-line favorite chip: name on top in class color, provenance
                                         subtitle below ("Maxroll · Endgame · S · added 3d ago"). Whole
                                         chip clicks = re-fetch + load; the ✕ in the corner removes the
                                         favorite without loading it. -->
                                    <Grid Margin="0,0,8,8" Width="220">
                                        <Button Command="{Binding LoadCommand}" ToolTip="{Binding Tip}"
                                                Background="{DynamicResource Surface.Card}" BorderThickness="0"
                                                HorizontalContentAlignment="Stretch"
                                                Padding="10,7" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="fb" Background="{TemplateBinding Background}"
                                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="fb" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{Binding ClassColor}"
                                                           FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Provenance}" Foreground="{DynamicResource Text.Muted}"
                                                           FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding RemoveCommand}"
                                                Content="✕" FontSize="11"
                                                Background="Transparent" BorderThickness="0" Padding="0"
                                                Foreground="{DynamicResource Text.Muted}" Cursor="Hand"
                                                MinWidth="18" MinHeight="18"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,4,6,0"
                                                ToolTip="Remove from favorites">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   FontSize="{TemplateBinding FontSize}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- ══════ Filter / Show controls ══════
                     Sits between the Favorites strip and the tier-list grid. Class checkboxes
                     are colored with the class's chip color so the row reads as a class palette
                     legend; the two show/hide toggles control chip metadata visibility globally. -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,24,0,0">
                    <DockPanel LastChildFill="True">
                        <!-- Right-side toggles: show class name subtitle / show ★ star button -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Show class name" IsChecked="{Binding ShowClassNames}"
                                      Foreground="{DynamicResource Text.Primary}" Margin="0,0,18,0" VerticalAlignment="Center"
                                      ToolTip="Show '(Sorcerer)' subtitle under each chip's build name" />
                            <CheckBox Content="Show ★ favorite" IsChecked="{Binding ShowFavoriteStars}"
                                      Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"
                                      ToolTip="Show the star toggle on every tier-list chip" />
                        </StackPanel>
                        <TextBlock Text="Show classes — uncheck to hide a class from every tier list"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text.Muted}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding ClassFilters}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each class checkbox: a thematic Unicode glyph + class name in
                                     the class's chip color. Glyph + color = double cue so the row
                                     reads at a glance (matches the chip-name palette in the grid
                                     below). All on by default; unchecking hides every chip of that
                                     class across all 3 tier sources. -->
                                <CheckBox IsChecked="{Binding IsEnabled}"
                                          Foreground="{Binding ClassColor}"
                                          FontWeight="SemiBold"
                                          Margin="0,0,16,4" VerticalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Glyph}" FontSize="14"
                                                   Margin="0,0,5,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ClassName}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ══════ This season's top builds — live community tier lists ══════
                     Three columns: D4Builds (left), Maxroll (middle), Mobalytics (right).
                     Every tier surfaced: S/A/B/C/D plus Mobalytics-only God Tier (top) and Support
                     (utility). Cards + chips at 25% opacity so the warlord background bleeds through. -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,30,0,0">
                    <TextBlock Text="This season's top builds" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Accent.Primary}" HorizontalAlignment="Center" />
                    <TextBlock Text="Pulled live from the community. Click any build to load it straight into the filter."
                               FontSize="11" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center" Margin="0,2,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- ── D4Builds (col 1, MIDDLE) ──
                             Moved to middle column 2026-05-28: D4Builds publishes the shortest tier list
                             of the three sources, so its empty bottom band in the middle column lines
                             up with the warlord watermark and lets him surface through naturally. -->
                        <Border Grid.Column="1" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="5,0,5,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding D4BuildsTierUrl}" />
                                    <TextBlock Text="D4Builds" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding D4BuildsTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectD4BuildsTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding D4BuildsTierStatus}" Foreground="{DynamicResource Text.Secondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding D4BuildsTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding D4BuildsTiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="4"
                                                        MinWidth="30" Height="26" VerticalAlignment="Top" Padding="6,0"
                                                        HorizontalAlignment="Center" Margin="0,1,4,0">
                                                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#1a1410" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- Star sits ABOVE the chip in z-order so it captures clicks
                                                                 in its tiny corner footprint; the rest of the chip area
                                                                 stays clickable for Load (chip Button beneath). -->
                                                            <Grid>
                                                                <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                                                        Foreground="{Binding ClassColor}"
                                                                        Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                                                <Button Style="{StaticResource FavStarBtn}"
                                                                        Content="{Binding IsFavorited, Converter={StaticResource FavStar}}"
                                                                        Foreground="{Binding IsFavorited, Converter={StaticResource FavStarBrush}}"
                                                                        Command="{Binding ToggleFavoriteCommand}"
                                                                        Margin="0,3,9,0"
                                                                        Visibility="{Binding DataContext.ShowFavoriteStars,
                                                                                     RelativeSource={RelativeSource AncestorType=Window},
                                                                                     Converter={StaticResource BoolToVis}}"
                                                                        ToolTip="Star to save under Your Favorites" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Maxroll (col 0, LEFT) ── moved from middle to left 2026-05-28 -->
                        <Border Grid.Column="0" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="0,0,5,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding MaxrollTierUrl}" />
                                    <TextBlock Text="Maxroll" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MaxrollTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectMaxrollTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MaxrollTierStatus}" Foreground="{DynamicResource Text.Secondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding MaxrollTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding MaxrollTiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="4"
                                                        MinWidth="30" Height="26" VerticalAlignment="Top" Padding="6,0"
                                                        HorizontalAlignment="Center" Margin="0,1,4,0">
                                                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#1a1410" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- Star sits ABOVE the chip in z-order so it captures clicks
                                                                 in its tiny corner footprint; the rest of the chip area
                                                                 stays clickable for Load (chip Button beneath). -->
                                                            <Grid>
                                                                <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                                                        Foreground="{Binding ClassColor}"
                                                                        Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                                                <Button Style="{StaticResource FavStarBtn}"
                                                                        Content="{Binding IsFavorited, Converter={StaticResource FavStar}}"
                                                                        Foreground="{Binding IsFavorited, Converter={StaticResource FavStarBrush}}"
                                                                        Command="{Binding ToggleFavoriteCommand}"
                                                                        Margin="0,3,9,0"
                                                                        Visibility="{Binding DataContext.ShowFavoriteStars,
                                                                                     RelativeSource={RelativeSource AncestorType=Window},
                                                                                     Converter={StaticResource BoolToVis}}"
                                                                        ToolTip="Star to save under Your Favorites" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Mobalytics (col 2, NEW) ── God + S/A/B/C + Support -->
                        <Border Grid.Column="2" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="6" Padding="14,12" Margin="5,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding MobalyticsTierUrl}" />
                                    <TextBlock Text="Mobalytics" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MobalyticsTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectMobalyticsTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MobalyticsTierStatus}" Foreground="{DynamicResource Text.Secondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding MobalyticsTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding MobalyticsTiers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="4"
                                                        MinWidth="30" Height="26" VerticalAlignment="Top" Padding="6,0"
                                                        HorizontalAlignment="Center" Margin="0,1,4,0">
                                                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#1a1410" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- Star sits ABOVE the chip in z-order so it captures clicks
                                                                 in its tiny corner footprint; the rest of the chip area
                                                                 stays clickable for Load (chip Button beneath). -->
                                                            <Grid>
                                                                <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                                                        Foreground="{Binding ClassColor}"
                                                                        Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                                                <Button Style="{StaticResource FavStarBtn}"
                                                                        Content="{Binding IsFavorited, Converter={StaticResource FavStar}}"
                                                                        Foreground="{Binding IsFavorited, Converter={StaticResource FavStarBrush}}"
                                                                        Command="{Binding ToggleFavoriteCommand}"
                                                                        Margin="0,3,9,0"
                                                                        Visibility="{Binding DataContext.ShowFavoriteStars,
                                                                                     RelativeSource={RelativeSource AncestorType=Window},
                                                                                     Converter={StaticResource BoolToVis}}"
                                                                        ToolTip="Star to save under Your Favorites" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="Tier lists belong to Maxroll.gg, D4Builds.gg, and Mobalytics.gg respectively — shown here with attribution."
                               FontSize="10" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
                </StackPanel>
              </Grid>
            </ScrollViewer>

            <!-- ─── LOADING STATE ─── -->
            <Grid Visibility="{Binding IsLoadingState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Compiling filter…" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{DynamicResource Text.Muted}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ─── RESULT STATE ─── -->
            <ScrollViewer Visibility="{Binding IsResultState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <!-- Result-page header: title on the left, ★ Favorite toggle on the right.
                         The star button only shows when the current build has a URL we can re-fetch
                         (CanFavoriteCurrent — false for pasted builds, true for any URL-based build).
                         Label flips between "★ Favorite this build" and "★ Favorited (click to remove)". -->
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ToggleFavoriteCurrentCommand}"
                                Visibility="{Binding CanFavoriteCurrent, Converter={StaticResource BoolToVis}}"
                                Background="Transparent" BorderBrush="{DynamicResource Accent.Primary}" BorderThickness="1"
                                Foreground="{Binding IsCurrentFavorited, Converter={StaticResource FavStarBrush}}"
                                Padding="10,4" FontSize="12" FontWeight="SemiBold"
                                Cursor="Hand" VerticalAlignment="Center"
                                ToolTip="Save this build to Your Favorites on the landing page">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock>
                                <Run Text="{Binding IsCurrentFavorited, Converter={StaticResource FavStar}, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="Favorite" />
                            </TextBlock>
                        </Button>
                        <!-- Build name + source-origin pill on the same row.
                             The pill (MAXROLL / D4BUILDS / MOBALYTICS / COMMUNITY) tells the user
                             at a glance which site the build came from — useful when comparing
                             favorites, attribution, or returning to source for updates. Brand-
                             colored via SourceBrush converter. Collapsed pre-load. -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BuildName}"
                                       FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                       VerticalAlignment="Center" />
                            <Border CornerRadius="9" Padding="9,2" Margin="12,3,0,0"
                                    Background="{Binding CurrentSource, Converter={StaticResource SourceBrush}}"
                                    Visibility="{Binding HasCurrentSource, Converter={StaticResource BoolToVis}}"
                                    VerticalAlignment="Center"
                                    ToolTip="Source of this build — click to reload from origin">
                                <TextBlock Text="{Binding CurrentSourceLabel}"
                                           Foreground="White" FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Text="{Binding BuildSubtitle}"
                               FontSize="12" Foreground="{DynamicResource Text.Secondary}" Margin="0,4,0,12" />

                    <!-- Variant picker — uncheck a variant to drop it from the combined pool -->
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Variants included (uncheck to narrow the filter — recompiles live)"
                                       Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding Variants}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  Content="{Binding Label}"
                                                  Margin="0,2,22,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: affix pool. beta.8.3: 3-column grid layout instead of a tall single
                             column — 27 affixes / 3 cols = 9 rows tall instead of 27. Pairs with the
                             right Legend tab going 2-col below. Result: both boxes ~200px tall, the
                             entire result page fits without scroll at 1080p so users don't scroll to
                             reach the Copy button. -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Top">
                            <TextBlock Text="Filterable affixes — these drive the gold / silver match"
                                       Style="{StaticResource SectionLabel}" />
                            <ListBox ItemsSource="{Binding PoolLines}" Height="172"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>

                            <TextBlock Text="Not yet filterable (dev — affixes the mapper hasn't resolved)"
                                       Style="{StaticResource SectionLabel}" Margin="0,12,0,4">
                                <TextBlock.Visibility>
                                    <MultiBinding Converter="{StaticResource AllTrueToVis}">
                                        <Binding Path="ShowPendingAffixes" />
                                        <Binding Path="HasDropped" />
                                    </MultiBinding>
                                </TextBlock.Visibility>
                            </TextBlock>
                            <ListBox ItemsSource="{Binding DroppedLines}" Height="120">
                                <ListBox.Visibility>
                                    <MultiBinding Converter="{StaticResource AllTrueToVis}">
                                        <Binding Path="ShowPendingAffixes" />
                                        <Binding Path="HasDropped" />
                                    </MultiBinding>
                                </ListBox.Visibility>
                            </ListBox>
                        </StackPanel>

                        <!-- Right: uniques / mythics / pending / color legend in a TabControl.
                             beta.8 polish: was 4 stacked sections + 4 fixed-height ListBoxes burning
                             ~360px of vertical with lots of dead air when only 1-2 categories were
                             populated.
                             beta.8.2: fixed Height 264 (instead of MaxHeight=300) so the right box is
                             exactly the same height as the left column (240 ListBox + 24 header label
                             = 264). Filter Options below snaps up since no asymmetric row stretch. -->
                        <Border Grid.Column="1" Margin="8,0,0,0" Background="{DynamicResource Surface.Panel}"
                                BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" CornerRadius="4"
                                VerticalAlignment="Top" Height="196">
                            <TabControl Background="Transparent" BorderThickness="0" Padding="10">
                                <TabControl.Resources>
                                    <Style TargetType="TabItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                        <Setter Property="Padding" Value="10,5" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TabItem">
                                                    <Border x:Name="b" Background="{TemplateBinding Background}"
                                                            BorderBrush="{DynamicResource Border.Strong}" BorderThickness="0,0,0,2"
                                                            Padding="{TemplateBinding Padding}" Margin="0,0,8,0">
                                                        <ContentPresenter ContentSource="Header"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TabControl.Resources>

                                <TabItem Header="Uniques">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Build uniques → purple"
                                                   Style="{StaticResource SectionLabel}"
                                                   Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />
                                        <ListBox ItemsSource="{Binding UniquePurpleLines}" MinHeight="120" MaxHeight="240"
                                                 Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />

                                        <TextBlock Text="Pending capture (resolved by name, no filter ID yet)"
                                                   Style="{StaticResource SectionLabel}" Margin="0,14,0,4"
                                                   Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />
                                        <ListBox ItemsSource="{Binding UniquePendingLines}" MinHeight="60" MaxHeight="120"
                                                 Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />

                                        <TextBlock Text="No uniques in this build."
                                                   Foreground="{DynamicResource Text.Muted}" FontSize="11" FontStyle="Italic" Margin="0,10,0,0"
                                                   Visibility="{Binding HasNoUniques, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Mythics">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Mythics — own category, left untouched (natural beam)"
                                                   Style="{StaticResource SectionLabel}"
                                                   Foreground="#ff6ec7"
                                                   Visibility="{Binding HasMythics, Converter={StaticResource BoolToVis}}" />
                                        <ListBox ItemsSource="{Binding MythicLines}" MinHeight="120" MaxHeight="240"
                                                 Visibility="{Binding HasMythics, Converter={StaticResource BoolToVis}}" />

                                        <TextBlock Text="No mythics in this build."
                                                   Foreground="{DynamicResource Text.Muted}" FontSize="11" FontStyle="Italic"
                                                   Visibility="{Binding HasNoMythics, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </TabItem>

                                <TabItem Header="Legend">
                                    <Border Background="{DynamicResource Surface.Inset}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                            CornerRadius="4" Padding="12,10" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}" Margin="0,0,0,6"
                                                       Text="What the colors mean (top rule wins)" />
                                            <!-- 2-col layout: 8 items / 2 = 4 rows, halves the vertical the legend used. -->
                                            <UniformGrid Columns="2">
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#a020f0" Text="● Purple" /><Run Text="  — build uniques" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#2251e8" Text="● Blue" /><Run Text="  — Greater Affix items" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#ffd700" Text="● Gold" /><Run Text="  — 3+ build affixes" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#00c800" Text="● Green" /><Run Text="  — Charms &amp; Seals" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#aaaaaa" Text="● Silver" /><Run Text="  — 2+ build affixes" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#ffffff" Text="● White" /><Run Text="  — Codex upgrades" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2"><Run Foreground="#ff8c00" Text="● Orange" /><Run Foreground="#00ffff" Text="/Cyan" /><Run Text="  — IP 900/850" /></TextBlock>
                                                <TextBlock Margin="0,2,8,2" Foreground="{DynamicResource Text.Muted}"><Run Text="◌ Hidden" /><Run Text="  — everything else" /></TextBlock>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>

                    <!-- Filter options — toggles recompile the code live -->
                    <TextBlock Text="Filter options" Style="{StaticResource SectionLabel}" Margin="0,10,0,4"
                               ToolTip="Each toggle is a rule the filter emits. Gold = 3+ build affixes per slot, Silver = 2+ (one roll away). Mythics are never touched." />
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                            CornerRadius="4" Padding="14,10">
                        <StackPanel>
                            <!-- ── Primary matching choice: per-slot mode + the two color-coded build-affix tiers ── -->
                            <CheckBox Content="Precise per-slot rules (recommended)" IsChecked="{Binding OptPerSlot}"
                                      Foreground="{Binding OptPerSlot, Converter={StaticResource ActiveText}}" Margin="0,0,0,6"
                                      ToolTip="ON: each gear slot gets its own rule, scoped to that item type (a boots rule only matches boots). OFF: matches by affix COUNT across ALL slots, which can show false 'keeps' (e.g. boots that rolled chest/ring stats)." />
                            <!-- beta.8.1: every row uses a 2-col Grid (32px chip slot | checkbox+label)
                                 so every checkbox locks to x=32 regardless of how many chips a row
                                 carries. Fixes the Item Power row pushing right because it has 2 chips. -->
                            <UniformGrid Columns="2">
                                <!-- 3+ → Gold -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptGoldTier, Converter={StaticResource ActiveColor}, ConverterParameter=#FFD700}" />
                                    <CheckBox Grid.Column="1" Content="3+ affixes per slot → Gold (best items)" IsChecked="{Binding OptGoldTier}"
                                              Foreground="{Binding OptGoldTier, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- 2+ → Silver -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptSilverTier, Converter={StaticResource ActiveColor}, ConverterParameter=#AAAAAA}" />
                                    <CheckBox Grid.Column="1" Content="2+ affixes per slot → Silver (one roll away)" IsChecked="{Binding OptSilverTier}"
                                              Foreground="{Binding OptSilverTier, Converter={StaticResource ActiveText}}" />
                                </Grid>
                            </UniformGrid>

                            <Border Height="1" Background="{DynamicResource Border.Subtle}" Margin="0,10,0,10" />

                            <!-- ── Secondary tiers (each marker shows its in-game highlight color, grays when off) ──
                                 beta.8.4: 2-col → 4-col. 8 toggles → 2 rows × 4 cols instead of 4 rows × 2.
                                 Saves ~65px vertical. Each cell at 1600px window = ~290px — fits the longest
                                 label "Item power 900/850 → Orange/Cyan" (chip slot + checkbox + label ≈ 210px). -->
                            <UniformGrid Columns="4">
                                <!-- Build uniques → purple -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptBuildUniques, Converter={StaticResource ActiveColor}, ConverterParameter=#A020F0}" />
                                    <CheckBox Grid.Column="1" Content="Build uniques → Purple" IsChecked="{Binding OptBuildUniques}"
                                              Foreground="{Binding OptBuildUniques, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- Greater Affixes → blue -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptGreaterAffixes, Converter={StaticResource ActiveColor}, ConverterParameter=#2251E8}" />
                                    <CheckBox Grid.Column="1" Content="Greater Affixes → Blue" IsChecked="{Binding OptGreaterAffixes}"
                                              Foreground="{Binding OptGreaterAffixes, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- Item-power tiers → orange + cyan (TWO chips in the same fixed 32px slot,
                                     side-by-side centered, so the checkbox still locks to x=32) -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="13" Height="14" CornerRadius="3" Margin="0,0,2,0"
                                                Background="{Binding OptItemPowerTiers, Converter={StaticResource ActiveColor}, ConverterParameter=#FF8C00}" />
                                        <Border Width="13" Height="14" CornerRadius="3" Margin="2,0,0,0"
                                                Background="{Binding OptItemPowerTiers, Converter={StaticResource ActiveColor}, ConverterParameter=#00FFFF}" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Content="Item power 900/850 → Orange/Cyan"
                                              IsChecked="{Binding OptItemPowerTiers}"
                                              Foreground="{Binding OptItemPowerTiers, Converter={StaticResource ActiveText}}"
                                              ToolTip="Gearing aid — noisy at endgame (nearly every drop is max item power, so the highlight loses signal)." />
                                </Grid>
                                <!-- Charms &amp; Seals → green -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptCharmsSeals, Converter={StaticResource ActiveColor}, ConverterParameter=#00C800}" />
                                    <CheckBox Grid.Column="1" Content="Charms &amp; Seals → Green" IsChecked="{Binding OptCharmsSeals}"
                                              Foreground="{Binding OptCharmsSeals, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- Codex upgrades → white -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptCodex, Converter={StaticResource ActiveColor}, ConverterParameter=#FFFFFF}" />
                                    <CheckBox Grid.Column="1" Content="Codex upgrades → White" IsChecked="{Binding OptCodex}"
                                              Foreground="{Binding OptCodex, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- ── Behavioral toggles: no color emitted, so each gets the same hollow
                                     outline chip (#6b625a). Visually consistent — "this row has no chip
                                     color of its own; it changes filter behavior" reads the same for all 3. -->
                                <!-- Hide everything else -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="Transparent" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" />
                                    <CheckBox Grid.Column="1" Content="Hide everything else" IsChecked="{Binding OptHideRest}"
                                              Foreground="{Binding OptHideRest, Converter={StaticResource ActiveText}}"
                                              ToolTip="Hide commons/magics/rares/legendaries the rules above didn't match. Uniques and mythics always drop." />
                                </Grid>
                                <!-- Strict endgame (Ancestral only) -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="Transparent" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" />
                                    <CheckBox Grid.Column="1" Content="Strict endgame (Ancestral only)" IsChecked="{Binding StrictEndgame}"
                                              Foreground="{Binding StrictEndgame, Converter={StaticResource ActiveText}}"
                                              ToolTip="Gate the build-affix tiers to Ancestral (top item-power) gear — great for T6+, hides everything else while leveling." />
                                </Grid>
                                <!-- Show pending affixes (dev): off by default; surfaces the "Not yet
                                     filterable" diagnostic on the result page. Medick's mark — most users
                                     don't care which affixes haven't been mapped yet, that's our job. -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="Transparent" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" />
                                    <CheckBox Grid.Column="1" Content="Show pending affixes (dev)" IsChecked="{Binding ShowPendingAffixes}"
                                              Foreground="{Binding ShowPendingAffixes, Converter={StaticResource ActiveText}}"
                                              ToolTip="Surface the 'Not yet filterable' list on the result page — affixes the mapper couldn't resolve to a filter ID. Off by default since it's dev diagnostic info, not user info." />
                                </Grid>
                            </UniformGrid>
                            <!-- beta.8.3: the 2-paragraph explainer here moved into tooltips on
                                 "Filter options" header + "Precise per-slot rules" checkbox above —
                                 frees ~50px of vertical so the Copy button fits above the fold. -->
                        </StackPanel>
                    </Border>

                    <!-- Filter title (beta.8.3: inline row to save vertical — was stacked
                         label+box+note, now a single row "Filter title:  [box]  X/24 chars").
                         beta.8.4: bumped Margin top 10 → 40 + a 25-tall trailing gap below this row
                         (via Margin on the next section). That 65px gutter is intentional dead space
                         that lets the full-bleed warlord watermark surface — the design agent's read
                         is that consolidating the secondary toggles to 4-col exposes the warlord's
                         helm + shoulders through this band naturally, without staging. -->
                    <DockPanel LastChildFill="True" Margin="0,40,0,25">
                        <TextBlock DockPanel.Dock="Left" Text="Filter title" VerticalAlignment="Center"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,8,0"
                                   ToolTip="Becomes the filter's name in Diablo 4 when imported. D4 drops names longer than 24 chars." />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TitleLengthNote}"
                                   FontSize="11" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBox Text="{Binding FilterTitle, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="24" Height="30" FontSize="13" FontFamily="Segoe UI" />
                    </DockPanel>

                    <!-- Import code (beta.8): single-line monospace + Copy button welded right.
                         Was a 120px multiline wall of base64 dominating the page. The full code lives
                         in the Expander below for the curious; the primary affordance is just Copy. -->
                    <TextBlock Text="Import code" Style="{StaticResource SectionLabel}" Margin="0,12,0,4" />
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="📋 Copy"
                                Command="{Binding CopyCodeCommand}"
                                Width="110" Height="38" Margin="8,0,0,0" />
                        <TextBox Text="{Binding ImportCode, Mode=OneWay}"
                                 IsReadOnly="True" Height="38" FontSize="11"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Hidden"
                                 VerticalContentAlignment="Center" />
                    </DockPanel>
                    <DockPanel LastChildFill="True" Margin="0,6,0,0">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding FilterInfo}" Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center" FontSize="12" FontFamily="Consolas" />
                        <Expander Header="▾ Show full code" Foreground="{DynamicResource Text.Muted}" FontSize="11"
                                  HorizontalAlignment="Left">
                            <TextBox Text="{Binding ImportCode, Mode=OneWay}"
                                     IsReadOnly="True" MinHeight="100" MaxHeight="200" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" FontSize="11" Margin="0,6,0,0" />
                        </Expander>
                    </DockPanel>

                    <!-- Rule-cap warning: D4 rejects filters over 25 rules on import -->
                    <Border Background="{DynamicResource Danger.Bg}" BorderBrush="{DynamicResource Danger.Border}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding HasCapWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding CapWarning}" TextWrapping="Wrap" FontSize="12"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Danger.Fg}" />
                    </Border>

                    <!-- Re-import warning: options regenerate the code; an imported filter won't auto-update -->
                    <Border Background="{DynamicResource Caution.Bg}" BorderBrush="{DynamicResource Caution.Border}" BorderThickness="1"
                            CornerRadius="4" Padding="12,8" Margin="0,10,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Caution.Fg}">
                            <Run FontWeight="Bold" Text="⚠ Changed an option (e.g. toggled a Gold/Silver tier)?" />
                            <Run Text=" The code above is rebuilt every time you toggle something — but a filter you've ALREADY pasted into Diablo 4 won't update on its own. To apply a change: copy the new code and import it again, or check/uncheck the matching rules directly in the in-game filter." />
                        </TextBlock>
                    </Border>

                    <!-- How to import (beta.8: collapsed into an Expander since this is read-once
                         reference content — recovers ~140px of viewport from the read-only banner). -->
                    <Expander Header="? How to import into Diablo 4" Foreground="{DynamicResource Accent.Primary}" FontSize="12"
                              FontWeight="SemiBold" Margin="0,14,0,0">
                        <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Border.Input}" BorderThickness="1"
                                CornerRadius="4" Padding="14,12" Margin="0,6,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Text.Primary}" LineHeight="20">
                                <Run Text="1. In Diablo 4, open the Character menu and go to the Loot Filter tab." /><LineBreak />
                                <Run Text="2. Click Import / Export, then Import." /><LineBreak />
                                <Run Text="3. Paste the code above and confirm. The filter applies immediately." /><LineBreak />
                                <Run Text="Filters sync across platforms through your Battle.net account (25-rule cap; rules apply top-down, first match wins)." />
                            </TextBlock>
                        </Border>
                    </Expander>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="← Compile another build"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="220" Height="44" FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- ════════════════════════ FOOTER ════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource Surface.Panel}" Padding="12,6" CornerRadius="4" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="11" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center">
                    <Run Text="D4 Build Filter (preview)" />
                    <Run Text="  •  " />
                    <Run Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#8c8" />
                </TextBlock>

                <TextBlock Grid.Column="2" FontSize="10" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    Free community tool. Not affiliated with Blizzard or maxroll.gg.
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
