<Window x:Class="D4BuildFilter.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D4BuildFilter.WPF"
        xmlns:vm="clr-namespace:D4BuildFilter.WPF.ViewModels"
        xmlns:b="clr-namespace:D4BuildFilter.WPF.Behaviors"
        mc:Ignorable="d"
        Title="MedicK's Might — Filters Made EZ"
        Icon="Assets/mk_logo.png"
        Height="920" Width="1160"
        MinHeight="640" MinWidth="860"
        Background="{DynamicResource Surface.Page}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <!-- F5 = re-pull all tier lists + re-sync favorite tiers (same as the ⟳ button). -->
        <KeyBinding Key="F5" Command="{Binding RefreshTierListsCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ActiveColorConverter x:Key="ActiveColor" />
        <local:ActiveTextConverter x:Key="ActiveText" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <local:FavoriteStarConverter x:Key="FavStar" />
        <local:FavoriteStarBrushConverter x:Key="FavStarBrush" />
        <local:SourceToBrushConverter x:Key="SourceBrush" />
        <local:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
        <local:RecipeIconConverter x:Key="RecipeIcon" />
        <local:IconKeyToPathConverter x:Key="IconKey" />
        <local:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <local:StringEqualsConverter x:Key="StrEq" />
        <local:BoolToChevronConverter x:Key="ToChevron" />
        <local:NameToEmblemConverter x:Key="NameToEmblem" />
        <local:NameToCrestConverter x:Key="NameToCrest" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
        </Style>

        <!-- Primary action button — themed via Action.Primary tokens -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
            <Setter Property="Foreground" Value="{DynamicResource Action.Primary.Fg}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
            <Setter Property="FontSize" Value="{DynamicResource Type.Body}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="pb" Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="pbs" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="pbs" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="pbs" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="pbs" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="pbs" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg.Hover}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource Action.Disabled.Bg}" />
                    <Setter Property="Foreground" Value="{DynamicResource Action.Disabled.Fg}" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource Action.Secondary.Bg}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Action.Secondary.Bg.Hover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v1.0.5 input polish: comfortable 34px minimum + a gold focus ring so the active field
             is unmistakable (the stock 1px gray focus was invisible on the dark palette). -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Surface.Inset}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Input}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Text.Primary}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Surface.Inset}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Strong}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
            <Setter Property="FontSize" Value="{DynamicResource Type.BodySm}" />
        </Style>

        <!-- v1.0.5 FABLE PASS: fully drawn CheckBox — the stock Windows glyph box was the app's
             loudest "2000s WinForms" tell (it appears on every toggle in the product). 18px rounded
             box on Surface.Inset; checked = crimson Action.Primary fill + drawn white check. All
             brushes DynamicResource so the Default/Discord/Dark themes each restyle it live. -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
            <Setter Property="FontSize" Value="{DynamicResource Type.BodySm}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="box" Width="18" Height="18" CornerRadius="4"
                                    Background="{DynamicResource Surface.Inset}"
                                    BorderBrush="{DynamicResource Border.Input}" BorderThickness="1.5"
                                    VerticalAlignment="Center" SnapsToDevicePixels="True">
                                <Path x:Name="check" Data="M 3.6,7.8 L 6.6,10.8 L 11.6,4.2"
                                      Stroke="{DynamicResource Action.Primary.Fg}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Opacity="0" />
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0" RecognizesAccessKey="True"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- hover first, checked second: on conflict the LATER trigger wins, so a
                                 checked box keeps its crimson border while hovered. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Action.Primary.Bg}" />
                                <Setter TargetName="check" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- v1.0.5 FABLE PASS: flat themed ComboBox (Cube Sandbox rarity + GA pickers) — replaces
             the stock Windows dropdown chrome. Drawn chevron rotates open; popup is a floating
             themed card. Non-editable only (both usages are pick-lists). -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Margin="2,1" SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Sans}" />
            <Setter Property="FontSize" Value="{DynamicResource Type.BodySm}" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="field" Background="{DynamicResource Surface.Inset}"
                                    BorderBrush="{DynamicResource Border.Input}" BorderThickness="1"
                                    CornerRadius="{DynamicResource Radius.Control}" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="10,0,6,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                                    <Path x:Name="chevron" Grid.Column="1" Data="M 0,0 L 4,4 L 8,0"
                                          Stroke="{DynamicResource Accent.Primary}" StrokeThickness="1.8"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Margin="0,0,10,0" VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="chevronRot" Angle="0" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Border>
                            <!-- full-surface invisible toggle drives IsDropDownOpen -->
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" VerticalOffset="4"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                                   PopupAnimation="Fade" StaysOpen="False">
                                <Grid Margin="8">
                                    <Border Background="{DynamicResource Surface.Panel}"
                                            BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                            CornerRadius="8" Padding="3" Effect="{DynamicResource Elevation.Raised}"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="field" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="field" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="chevronRot" Storyboard.TargetProperty="Angle"
                                                             To="180" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="chevronRot" Storyboard.TargetProperty="Angle"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- v1.0.3: a section header that toggles a collapsible group. Strips all default button
             chrome so it reads as a clickable label + chevron (the chevron glyph flips via ToChevron). -->
        <Style x:Key="SectionToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- v1.0.5: reusable rotating chevron for the four collapsible section headers. A fixed "▸"
             glyph that rotates 0°→90° (collapsed→expanded) instead of swapping ▸/▾ instantly. The
             DataTrigger binds to the owning ToggleButton's IsChecked (the same *Expanded bool the
             content reveal uses), so the glyph and the content animate off one source of truth. -->
        <Style x:Key="SectionChevron" TargetType="TextBlock">
            <Setter Property="Text" Value="▸" />
            <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value><RotateTransform Angle="0" /></Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                 To="90" Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                 To="0" Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Slim transparent icon button for the 56px header chrome (Ko-fi / Discord), matching
             the theme-gear's look: transparent, gold glyph, card-hover background on mouseover. -->
        <Style x:Key="HeaderIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="hb" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource Radius.Control}">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="{DynamicResource Type.H2}"
                                       Foreground="{DynamicResource Accent.Primary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hb" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top-nav tab (Browse / Compile / Favorites). Active state is driven by the button's Tag
             (bound to the VM's Is*Tab bool): gold text + a 2px gold underline — the web-app nav signal. -->
        <Style x:Key="NavTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="{DynamicResource Type.Body}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,28,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="nb" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,2" Padding="2,11">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="nb" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clickable build "chip" used in the tier lists. Semi-transparent so the landing-page
             hero background bleeds through (the chip still reads clearly against the dimmed art). -->
        <Style x:Key="BuildChip" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Surface.Card}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Padding" Value="12,6" />
            <!-- v1.0.5: build names are the DATA on this page — bigger than BodySm(12), but 14 clips
                 the longest single words ("Counterswarm") in the narrow 3-across columns at the
                 default window width, so this is a deliberate off-ramp 13. -->
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <!-- Right-click → open this build on its source site (link-out + attribution model).
                 A ContextMenu isn't in the visual tree, so the command binds through PlacementTarget
                 back to the chip's TierBuildVM. -->
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="Open on source site ↗"
                                  Command="{Binding PlacementTarget.DataContext.OpenSourceCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource Radius.Card}"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="bt" Y="0" />
                            </Border.RenderTransform>
                            <!-- v1.0.4: dressed-up build chip — a class-color LEFT RAIL + the class's own
                                 EMBLEM (tinted its class color) + the build name in the class color, with
                                 an optional class subtitle (ShowClassNames toggle). Turns the plain text
                                 list into a class-colored card grid. All art is original (ClassEmblems). -->
                            <StackPanel Margin="6,7,6,8">
                                <!-- Emblem centered ON TOP so the build name keeps the full (narrow)
                                     chip width instead of wrapping to shreds. Class emblem tinted its
                                     class color; name in the class color; class subtitle below. -->
                                <!-- v1.0.5: 24px — the licensed game-icons carry more detail than the
                                     old hand-drawn emblems and earn the extra 2px. -->
                                <Rectangle Width="24" Height="24" Fill="{Binding ClassColor}"
                                           HorizontalAlignment="Center" Margin="0,0,0,5">
                                    <Rectangle.OpacityMask>
                                        <VisualBrush Stretch="Uniform" AlignmentX="Center" AlignmentY="Center"
                                                     Visual="{Binding ClassName, Converter={StaticResource NameToEmblem}}" />
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <!-- WrapWithOverflow (not Wrap): breaks at spaces only, so long single
                                     words ("Penetrating", "Heartseeker") overflow a hair instead of
                                     shredding to "Penetratin g" in the narrow 3-across columns. -->
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{Binding ClassColor}"
                                           FontSize="{TemplateBinding FontSize}" FontWeight="SemiBold"
                                           TextWrapping="WrapWithOverflow" TextAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Opacity="0.75" FontSize="{DynamicResource Type.Caption}"
                                           Foreground="{DynamicResource Text.Muted}" Margin="0,2,0,0"
                                           TextAlignment="Center" HorizontalAlignment="Center"
                                           Visibility="{Binding DataContext.ShowClassNames,
                                                        RelativeSource={RelativeSource AncestorType=Window},
                                                        Converter={StaticResource BoolToVis}}">
                                    <Run Text="{Binding ClassName, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent.Primary}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Primary}" />
                                <!-- Signature web-card hover lift: rise 2px, eased. -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bt" Storyboard.TargetProperty="Y"
                                                             To="-2" Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bt" Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tiny star button overlaid on a chip's top-right corner. Click toggles favorited state
             on the chip's VM; rest of the chip area stays clickable for Load (the star Button only
             captures clicks within its small footprint, the chip Button beneath gets the rest). -->
        <Style x:Key="FavStarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tier-list source tab (Endgame / Bossing / Leveling / Push / Speedfarm etc).
             Active state pulled from the TierTabVM.IsActive property — gold-on-dark when selected,
             dim-cream-on-transparent otherwise. -->
        <!-- v1.0.5 FABLE PASS: filled-pill tabs. The active tab was near-invisible (same hover-gray
             as mouseover); now it's a solid gold pill with dark text — unmissable. Trigger order
             matters: IsActive is declared LAST so an active tab keeps its fill while hovered. -->
        <Style x:Key="TierTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Muted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Subtle}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="{DynamicResource Radius.Pill}"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent.Primary}" />
                    <Setter Property="Foreground" Value="{DynamicResource Text.OnAccent}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Small text link button ("view full list ↗") -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Accent.Link}" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Accent.Link.Hover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v1.0.5 FABLE PASS: THE shared tier-row template — one source of truth for all three
             source columns (was copy-pasted 3×, so every badge tweak had to land three times).
             Badge went pill → 36px SQUARE (radius 6), bold BodyLg letter, on the classic tier-list
             heat ramp (S red → D blue, see TierGroupVM.BadgeFor). GOD/SUP stretch via MinWidth. -->
        <DataTemplate x:Key="TierRowTemplate">
            <Grid Margin="0,3,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{Binding Badge}" CornerRadius="6"
                        MinWidth="36" Height="36" VerticalAlignment="Top" Padding="4,0"
                        HorizontalAlignment="Center" Margin="0,1,4,0">
                    <TextBlock Text="{Binding BadgeText}" FontWeight="Bold" FontSize="{DynamicResource Type.BodyLg}"
                               Foreground="{DynamicResource Text.OnAccent}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Builds}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Star sits ABOVE the chip in z-order so it captures clicks in its tiny
                                 corner footprint; the rest of the chip stays clickable for Load. -->
                            <Grid>
                                <Button Style="{StaticResource BuildChip}" Content="{Binding Name}"
                                        Foreground="{Binding ClassColor}"
                                        Command="{Binding LoadCommand}" ToolTip="{Binding Tip}" />
                                <!-- Independent additive selector. It occupies only the top-left
                                     checkbox hit area; clicking anywhere else still runs LoadCommand. -->
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Left" VerticalAlignment="Top"
                                          Margin="5,5,0,0" Panel.ZIndex="2"
                                          ToolTip="Add this build to a Super Build (up to 4)" />
                                <ComboBox Width="42" Height="22"
                                          HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                          Margin="0,0,5,5" Panel.ZIndex="3"
                                          ItemsSource="{Binding PriorityChoices}"
                                          SelectedItem="{Binding Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Visibility="{Binding HasPriority, Converter={StaticResource BoolToVis}}"
                                          ToolTip="Build priority. Choosing an occupied number swaps the two builds." />
                                <Button Style="{StaticResource FavStarBtn}"
                                        Content="{Binding IsFavorited, Converter={StaticResource FavStar}}"
                                        Foreground="{Binding IsFavorited, Converter={StaticResource FavStarBrush}}"
                                        Command="{Binding ToggleFavoriteCommand}"
                                        Margin="0,3,9,0"
                                        Visibility="{Binding DataContext.ShowFavoriteStars,
                                                     RelativeSource={RelativeSource AncestorType=Window},
                                                     Converter={StaticResource BoolToVis}}"
                                        ToolTip="Star to save under Your Favorites" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="Auto" />   <!-- top-nav tab strip (web-app shell) -->
            <RowDefinition Height="*" />      <!-- body -->
            <RowDefinition Height="Auto" />   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════ HEADER: slim 56px chrome, always visible across all states.
             Replaced the old 260px working banner with a slim wordmark + state indicator so the
             working screens (Result/Options/Loading) recover ~200px of vertical real estate. The
             landing's centered brand callout still sits inside the input column for hero treatment;
             this slim bar is the persistent chrome that anchors every state. ════════════════════ -->
        <Border Grid.Row="0" Height="56" Background="{DynamicResource Surface.Header}" Margin="0,0,0,10"
                BorderBrush="{DynamicResource Border.Subtle}" BorderThickness="0,0,0,1" CornerRadius="0">
            <DockPanel LastChildFill="True" Margin="18,0">
                <!-- Right: theme picker gear → opens popup with 3 radio options + brand-color swatches.
                     beta.8.5: ThemeManager swaps the active Themes/*.xaml dictionary live; choice
                     persists to %LOCALAPPDATA%\MedicKsMight\theme.json. -->
                <Button x:Name="ThemePickerAnchor" DockPanel.Dock="Right"
                        Command="{Binding ToggleThemePickerCommand}"
                        Background="Transparent" BorderThickness="0" Padding="8,2"
                        VerticalAlignment="Center" Cursor="Hand"
                        Width="38" Height="38" Margin="6,0,0,0"
                        ToolTip="Pick a theme — Default / Discord / Dark">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="gb" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource Radius.Control}"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="⚙" FontSize="{DynamicResource Type.H1}"
                                           Foreground="{DynamicResource Accent.Primary}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="gb" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Popup IsOpen="{Binding IsThemePickerOpen}" StaysOpen="False"
                       PlacementTarget="{Binding ElementName=ThemePickerAnchor}" Placement="Bottom"
                       HorizontalOffset="-200" VerticalOffset="6" AllowsTransparency="True">
                    <Border Background="{DynamicResource Surface.Panel}"
                            BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Card}" Padding="14,12" MinWidth="240">
                        <StackPanel>
                            <TextBlock Text="Theme" Style="{StaticResource SectionLabel}" Margin="0,0,0,8" />
                            <!-- Each row = a brand swatch + a radio. Two-way StrEq binding makes the
                                 radio reflect SelectedTheme and set it on click. SelectedTheme's setter
                                 hooks into ThemeManager.Apply via the partial OnSelectedThemeChanged. -->
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Border Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}" Margin="0,0,8,0"
                                        Background="#d4af37" VerticalAlignment="Center" />
                                <RadioButton GroupName="ThemePicker" Content="Default — Warlord gold + crimson"
                                             Foreground="{DynamicResource Text.Primary}"
                                             VerticalContentAlignment="Center"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource StrEq}, ConverterParameter=Default}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Border Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}" Margin="0,0,8,0"
                                        Background="#5865f2" VerticalAlignment="Center" />
                                <RadioButton GroupName="ThemePicker" Content="Discord — blurple greys"
                                             Foreground="{DynamicResource Text.Primary}"
                                             VerticalContentAlignment="Center"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource StrEq}, ConverterParameter=Discord}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Border Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}" Margin="0,0,8,0"
                                        Background="#22d3ee" VerticalAlignment="Center" />
                                <RadioButton GroupName="ThemePicker" Content="Dark — true black + cyan"
                                             Foreground="{DynamicResource Text.Primary}"
                                             VerticalContentAlignment="Center"
                                             IsChecked="{Binding SelectedTheme, Converter={StaticResource StrEq}, ConverterParameter=Dark}" />
                            </StackPanel>
                            <!-- Theme-agnostic toggle: when ON, ThemeManager forces Surface.Panel
                                 + Surface.Inset opacity to ~65% so the warlord watermark surfaces
                                 through cards/inputs. Applies on top of any theme; re-applies on
                                 theme swap (so a Default→Discord switch keeps the translucency). -->
                            <Border Background="{DynamicResource Border.Subtle}" Height="1" Margin="0,10,0,8" />
                            <CheckBox IsChecked="{Binding TranslucentPanels}"
                                      Content="Translucent panels"
                                      Foreground="{DynamicResource Text.Primary}"
                                      ToolTip="Adds transparency to the panel backgrounds." />
                            <!-- Game data: the affix/unique name files the compiler resolves against.
                                 The bundled copies freeze at build time; this pulls the current
                                 season's pair from the Diablo4Companion repo so new affixes resolve
                                 without waiting on an app release. Validated before install; falls
                                 back to bundled if anything's off. -->
                            <Border Background="{DynamicResource Border.Subtle}" Height="1" Margin="0,10,0,8" />
                            <TextBlock Text="Game data" Style="{StaticResource SectionLabel}" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding GameDataLabel}"
                                       FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}"
                                       TextWrapping="Wrap" MaxWidth="260" Margin="0,0,0,4" />
                            <Button Style="{StaticResource LinkButton}" HorizontalAlignment="Left"
                                    Command="{Binding UpdateGameDataCommand}" Content="⟳ Update game data"
                                    ToolTip="Download the latest affix + unique data — new seasons add items the bundled data hasn't heard of." />
                            <TextBlock Text="{Binding GameDataStatus}"
                                       FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Caution.Fg}"
                                       TextWrapping="Wrap" MaxWidth="260" Margin="0,4,0,0" />
                            <TextBlock Text="Persists across launches"
                                       FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </Popup>
                <!-- Support + community: Ko-fi (☕) and Discord (💬). Icon-only to fit the 56px bar;
                     tooltips spell them out. Both open placeholder URLs until the accounts exist. -->
                <Button DockPanel.Dock="Right" Command="{Binding OpenDiscordCommand}"
                        Style="{StaticResource HeaderIcon}" Content="💬"
                        ToolTip="Join the Medick's Might Discord" />
                <Button DockPanel.Dock="Right" Command="{Binding OpenKofiCommand}"
                        Style="{StaticResource HeaderIcon}" Content="☕"
                        ToolTip="Support the project on Ko-fi" />
                <!-- Build name on the right of the build-name area, before the gear -->
                <TextBlock DockPanel.Dock="Right" Text="{Binding BuildName}"
                           VerticalAlignment="Center" FontSize="{DynamicResource Type.Body}" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Primary}" TextTrimming="CharacterEllipsis"
                           Margin="0,0,12,0"
                           Visibility="{Binding IsResultState, Converter={StaticResource BoolToVis}}" />
                <!-- Left: MK monogram + wordmark + slogan -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/mk_logo.png" Width="36" Height="36"
                           Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center" />
                    <TextBlock FontSize="{DynamicResource Type.H2}" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#d4af37" BlurRadius="12" ShadowDepth="0" Opacity="0.25" />
                        </TextBlock.Effect>
                        <Run Text="M" Foreground="{DynamicResource Accent.Secondary}" /><Run Text="edic" Foreground="{DynamicResource Accent.Primary}" /><Run Text="K" Foreground="{DynamicResource Accent.Secondary}" /><Run Text="'s Might" Foreground="{DynamicResource Accent.Primary}" />
                    </TextBlock>
                    <TextBlock Text="Filters Made EZ" VerticalAlignment="Center" Margin="10,0,0,0"
                               FontSize="{DynamicResource Type.BodySm}" FontStyle="Italic" FontWeight="SemiBold" Foreground="{DynamicResource Text.Secondary}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════ TOP-NAV TAB STRIP (web-app shell): Browse / Compile / Favorites, gold active underline ════ -->
        <Border Grid.Row="1" Background="{DynamicResource Surface.Header}"
                BorderBrush="{DynamicResource Border.Subtle}" BorderThickness="0,0,0,1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="18,0">
                <Button Content="Browse" Style="{StaticResource NavTab}" Tag="{Binding IsBrowseTab}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Browse" />
                <Button Content="Paste a build" Style="{StaticResource NavTab}" Tag="{Binding IsCompileTab}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Compile" />
                <Button Content="Favorites" Style="{StaticResource NavTab}" Tag="{Binding IsFavTab}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Favorites" />
                <Button Content="Artwork" Style="{StaticResource NavTab}" Tag="{Binding IsArtworkTab}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Artwork"
                        ToolTip="Gallery mode — just the warlord, full strength" />
                <Button Content="Crafting Coach" Style="{StaticResource NavTab}" Tag="{Binding IsCoachTab}"
                        Command="{Binding SelectTabCommand}" CommandParameter="Coach"
                        ToolTip="The Horadric Cube, decoded — follow along and do an actual craft" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════ BODY ════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- FULL-PAGE WATERMARK: warlord art behind all content across every state, dimmed to
                 22% so the gold/crimson UI reads cleanly on Result/Options too. IsHitTestVisible=
                 False so it never intercepts clicks. Was landing-only at 55%; promoted in beta.8 to
                 unify the brand presence across screens (per design review). -->
            <Image Source="Assets/hero.jpg" Stretch="UniformToFill" Opacity="{DynamicResource Watermark.Opacity}"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   IsHitTestVisible="False" />

            <!-- ─── INPUT STATE ─── -->
            <ScrollViewer x:Name="InputScroll"
                          Visibility="{Binding IsInputState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <!-- InputColumn.Width is pinned to the ScrollViewer viewport in code-behind, so the
                   WrapPanels wrap against a finite width and centering works (a plain Disabled
                   ScrollViewer otherwise sizes its content to the widest tier row). -->
              <Grid>
                <StackPanel x:Name="InputColumn" HorizontalAlignment="Left" Margin="0,4,0,16">

                <!-- ══════ Landing manifesto + tagline ══════
                     The MK monogram + wordmark already sits in the slim 56px chrome above; this
                     callout is just the value-prop tagline + manifesto, so the landing keeps its
                     hero feeling without burning 220px of vertical on a redundant logo lockup. -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,4"
                            Visibility="{Binding IsCompileTab, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Turn any Diablo 4 build into a ready-to-import loot filter"
                               HorizontalAlignment="Center" FontSize="{DynamicResource Type.H2}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Primary}" />
                    <!-- Brand slogan kept (it's part of the MedicK's Might identity) but demoted from
                         bold-gold to a quiet muted sub-slogan so it stops out-shouting the Compile CTA.
                         Gold is reserved for section labels + the wordmark now. -->
                    <TextBlock Text="The gold standard in loot-filter standardization for Diablo 4"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               FontSize="{DynamicResource Type.Caption}" FontWeight="Normal" Foreground="{DynamicResource Text.Muted}"
                               TextAlignment="Center" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" MaxWidth="660" Margin="0,16,0,0"
                            Visibility="{Binding IsCompileTab, Converter={StaticResource BoolToVis}}">

                    <!-- Source toggle: maxroll URL vs. paste from any guide -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Button Content="maxroll URL" Command="{Binding UseUrlModeCommand}" Width="150" Height="34">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUrlMode}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Paste affixes" Command="{Binding UsePasteModeCommand}" Width="150" Height="34" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPasteMode}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Action.Primary.Bg}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- URL mode -->
                    <StackPanel Visibility="{Binding IsUrlMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste a maxroll, mobalytics, or d4builds build URL"
                                   FontSize="{DynamicResource Type.H2}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="maxroll.gg/d4/planner/…  ·  mobalytics.gg/diablo-4/builds/…  ·  d4builds.gg/builds/…"
                                   FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center" Margin="0,0,0,16"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <TextBox Text="{Binding MaxrollUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="34" FontSize="{DynamicResource Type.Body}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Make my loot filter"
                                    Command="{Binding CompileCommand}"
                                    Width="200" Height="44" FontSize="{DynamicResource Type.Body}" Margin="0,0,12,0" />
                            <Button Content="Try it with a sample build"
                                    Command="{Binding LoadSampleCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="220" Height="44" FontSize="{DynamicResource Type.Body}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Paste mode (universal: any build guide) -->
                    <StackPanel Visibility="{Binding IsPasteMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Paste an affix list from any build guide"
                                   FontSize="{DynamicResource Type.H2}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="One affix per line (or comma-separated); include unique item names. Works with d4builds, Mobalytics, Icy Veins, Discord…"
                                   FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" Margin="0,0,0,12" />
                        <TextBox Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="620" Height="200" FontSize="{DynamicResource Type.BodySm}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <Button Content="Make my loot filter"
                                Command="{Binding CompilePasteCommand}"
                                Width="220" Height="44" FontSize="{DynamicResource Type.Body}"
                                HorizontalAlignment="Center" Margin="0,16,0,0" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Caution.Fg}"
                               HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="{DynamicResource Type.BodySm}"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="620" />
                </StackPanel>

                <!-- ══════ Crafting Coach (v1.0.2 wing — CRAFTING_COACH_SPEC.md) ══════
                     A follow-along, second-screen Horadric Cube coach. Landing = goal cards +
                     dust decoder; picking a craft enters a big-type step flow. Content mirrors
                     the verified S14 recipe research; honest ranges, no invented percentages. -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,24,0,0" MaxWidth="900"
                            Visibility="{Binding IsCoachTab, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}" Text="Crafting Coach" />
                    <TextBlock FontSize="14" Foreground="{DynamicResource Text.Muted}" Margin="0,2,0,0"
                               Text="the Horadric Cube, decoded — follow along on this screen, craft on the other" />
                    <TextBlock FontSize="11" Foreground="{DynamicResource Text.Muted}" FontStyle="Italic" Margin="0,2,0,0"
                               Text="Recipes verified: S14 patch 3.1.x" />
                    <TextBlock FontSize="14" Foreground="#8c8" Margin="0,10,0,0" TextWrapping="Wrap"
                               Text="{Binding Coach.BuildLine, Mode=OneWay}" />

                    <!-- ── LANDING: goal cards ── -->
                    <StackPanel Visibility="{Binding Coach.IsLanding, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}"
                                   Text="What do you want to do?" Margin="0,18,0,8" />
                        <ItemsControl ItemsSource="{Binding Coach.Crafts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,10,10" Padding="16,12" HorizontalContentAlignment="Left"
                                            IsEnabled="{Binding Enabled}"
                                            Command="{Binding DataContext.Coach.PickCraftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Icon, Mode=OneWay}" Width="30" Height="30" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding Icon, Converter={StaticResource StringToVis}}" />
                                                <TextBlock FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding Emoji, Mode=OneWay}"
                                                           Margin="0,0,8,0" Visibility="{Binding Icon, Converter={StaticResource EmptyToVis}}" />
                                                <TextBlock FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding GoalTitle, Mode=OneWay}" />
                                            </StackPanel>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource Text.Muted}" TextWrapping="Wrap"
                                                       Text="{Binding GoalBlurb, Mode=OneWay}" Margin="0,3,0,0" />
                                            <TextBlock FontSize="11" Foreground="{DynamicResource Text.Muted}" FontStyle="Italic"
                                                       Text="coming soon" Margin="0,3,0,0"
                                                       Visibility="{Binding ComingSoon, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="🧪 Open the Cube Sandbox — rehearse any craft on a pretend item"
                                Margin="0,4,10,4" Padding="16,10" FontSize="15" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Command="{Binding Coach.OpenSandboxCommand}" />

                        <!-- dust decoder -->
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}"
                                   Text="What's all this dust? — mat decoder" Margin="0,16,0,8" />
                        <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="16,12" Effect="{DynamicResource Elevation.Card}">
                            <ItemsControl ItemsSource="{Binding Coach.DustTiers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,3" LastChildFill="True">
                                            <!-- the in-game item card art; the emoji glyph stands in where art is missing -->
                                            <Grid DockPanel.Dock="Left" Width="30" Margin="0,0,10,0">
                                                <Image Source="{Binding Icon, Mode=OneWay}" Height="42" VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding Icon, Converter={StaticResource StringToVis}}" />
                                                <TextBlock Text="{Binding Glyph, Mode=OneWay}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Icon, Converter={StaticResource EmptyToVis}}" />
                                            </Grid>
                                            <TextBlock FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}" />
                                                <Run Text=" — " Foreground="{DynamicResource Text.Muted}" /><Run Text="{Binding Blurb, Mode=OneWay}" Foreground="{DynamicResource Text.Muted}" />
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- ── FLOW: the follow-along coach ── -->
                    <StackPanel Visibility="{Binding Coach.IsCoaching, Converter={StaticResource BoolToVis}}">
                        <DockPanel Margin="0,16,0,8" LastChildFill="True">
                            <Button DockPanel.Dock="Left" Content="◂ all crafts" Padding="10,4"
                                    Command="{Binding Coach.BackToGoalsCommand}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{Binding Coach.SelectedCraft.Icon, Mode=OneWay}" Width="28" Height="28" Margin="0,0,8,0"
                                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                                       Visibility="{Binding Coach.SelectedCraft.Icon, Converter={StaticResource StringToVis}}" />
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}" VerticalAlignment="Center"
                                           Text="{Binding Coach.SelectedCraft.GoalTitle, Mode=OneWay}" />
                            </StackPanel>
                        </DockPanel>

                        <!-- persistent recipe strip: item >>> mats >>> cube >>> result -->
                        <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="16,12" Effect="{DynamicResource Elevation.Card}">
                            <TextBlock FontSize="16" TextWrapping="Wrap" TextAlignment="Center">
                                <Run Text="{Binding Coach.SelectedCraft.StripItem, Mode=OneWay}" FontWeight="SemiBold" />
                                <Run Text="   +   " Foreground="{DynamicResource Text.Muted}" />
                                <Run Text="{Binding Coach.SelectedCraft.StripMats, Mode=OneWay}" Foreground="#8c8" />
                                <Run Text="   →  🧪  →   " Foreground="{DynamicResource Text.Muted}" />
                                <Run Text="{Binding Coach.SelectedCraft.StripResult, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}" />
                            </TextBlock>
                        </Border>

                        <!-- the current step — big type, one thing at a time -->
                        <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="20,16" Margin="0,10,0,0" Effect="{DynamicResource Elevation.Card}">
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="{DynamicResource Accent.Primary}" FontWeight="SemiBold"
                                           Text="{Binding Coach.StepLabel, Mode=OneWay}" />
                                <TextBlock FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,10"
                                           Text="{Binding Coach.CurrentStep.Title, Mode=OneWay}" />
                                <ItemsControl ItemsSource="{Binding Coach.CurrentStep.Lines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="16" TextWrapping="Wrap" Margin="0,4" Text="{Binding Mode=OneWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock FontSize="14" FontStyle="Italic" Foreground="{DynamicResource Accent.Primary}" TextWrapping="Wrap"
                                           Margin="0,10,0,0" Text="{Binding Coach.CurrentStep.Tip, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <DockPanel Margin="0,12,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Left" Content="◂ back" Padding="14,8" FontSize="14"
                                    Command="{Binding Coach.PrevStepCommand}" />
                            <Button DockPanel.Dock="Right" Content="next step ▸" Padding="18,8" FontSize="14" FontWeight="SemiBold"
                                    Command="{Binding Coach.NextStepCommand}" />
                        </DockPanel>
                    </StackPanel>

                    <!-- ── SANDBOX: rehearse any craft on a simulated item ── -->
                    <StackPanel Visibility="{Binding Coach.IsSandbox, Converter={StaticResource BoolToVis}}">
                        <DockPanel Margin="0,16,0,8" LastChildFill="True">
                            <Button DockPanel.Dock="Left" Content="◂ back to coach" Padding="10,4"
                                    Command="{Binding Coach.BackToGoalsCommand}" />
                            <TextBlock FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Text="🧪 The Cube — Sandbox" />
                        </DockPanel>

                        <!-- the pretend item: four switches -->
                        <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="16,10" Effect="{DynamicResource Elevation.Card}">
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="Your pretend item:" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Accent.Primary}" Margin="0,0,12,0" />
                                <ComboBox ItemsSource="{Binding Coach.Sandbox.RarityOptions}" SelectedItem="{Binding Coach.Sandbox.SelectedRarity}"
                                          Width="120" VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="⭐ GAs:" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ComboBox ItemsSource="{Binding Coach.Sandbox.GaOptions}" SelectedItem="{Binding Coach.Sandbox.GreaterAffixes}"
                                          Width="55" VerticalAlignment="Center" Margin="0,0,14,0" />
                                <CheckBox Content="850+ Item Power" IsChecked="{Binding Coach.Sandbox.Power850Plus}"
                                          FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0" />
                                <CheckBox Content="open affix slot" IsChecked="{Binding Coach.Sandbox.OpenSlot}"
                                          FontSize="14" VerticalAlignment="Center" />
                            </WrapPanel>
                        </Border>
                        <TextBlock FontSize="12" FontStyle="Italic" Foreground="{DynamicResource Text.Muted}" Margin="2,4,0,8"
                                   Text="Flip the switches to set your item. Recipes it can't use are dimmed. Pick a recipe to see its materials and the honest result." />

                        <!-- RECIPES list (grouped, game style) + detail panel -->
                        <Grid MinHeight="430">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- left: the categorized recipe list -->
                            <Border Grid.Column="0" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}"
                                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Card}" Padding="4,6" Margin="0,0,10,0"
                                    Effect="{DynamicResource Elevation.Card}">
                                <ListBox ItemsSource="{Binding Coach.Sandbox.RecipesView}"
                                         SelectedItem="{Binding Coach.Sandbox.SelectedRecipe, Mode=TwoWay}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="row" Background="Transparent" BorderThickness="1"
                                                                BorderBrush="Transparent" CornerRadius="4" Padding="8,7" Margin="2,1">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="row" Property="Background" Value="#332020" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="row" Property="Background" Value="#7A1E1E" />
                                                                <Setter TargetName="row" Property="BorderBrush" Value="#DC0000" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Margin="6,10,0,4"
                                                               Foreground="{DynamicResource Accent.Primary}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Opacity="{Binding Eligible, Converter={StaticResource BoolToOpacity}}">
                                                <Image Source="{Binding Name, Converter={StaticResource RecipeIcon}}" Width="26" Height="26"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                                                <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="15" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Text.Primary}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- right: the selected recipe's detail (game's REQUIRED MATERIALS panel) -->
                            <Border Grid.Column="1" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}"
                                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Card}" Padding="22,18"
                                    Effect="{DynamicResource Elevation.Card}" DataContext="{Binding Coach.Sandbox.SelectedRecipe}">
                                <StackPanel>
                                    <!-- recipe title -->
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Name, Converter={StaticResource RecipeIcon}}" Width="34" Height="34"
                                               Margin="0,0,10,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="22" FontWeight="Bold"
                                                       Foreground="{DynamicResource Text.Primary}" />
                                            <TextBlock Text="{Binding Category, Mode=OneWay}" FontSize="12"
                                                       Foreground="{DynamicResource Text.Muted}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ineligible banner: why the current pretend item can't use this -->
                                    <Border Margin="0,12,0,0" Padding="12,8" CornerRadius="4" Background="#3A1414" BorderBrush="#C64545" BorderThickness="1"
                                            Visibility="{Binding Requirement, Converter={StaticResource StringToVis}}">
                                        <TextBlock FontSize="13" Foreground="#F0A0A0" TextWrapping="Wrap">
                                            <Run Text="Your pretend item can't use this: " /><Run Text="{Binding Requirement, Mode=OneWay}" FontWeight="SemiBold" />
                                        </TextBlock>
                                    </Border>

                                    <!-- what it does (honest outcome lines) -->
                                    <ItemsControl ItemsSource="{Binding Outcome}" Margin="0,14,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="15" TextWrapping="Wrap" Margin="0,3" Text="{Binding Mode=OneWay}"
                                                           Foreground="{DynamicResource Text.Primary}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- REQUIRED MATERIALS (game-style rows: icon + name + ×qty) -->
                                    <TextBlock Text="REQUIRED MATERIALS" FontSize="12" FontWeight="Bold" Margin="0,18,0,2"
                                               Foreground="{DynamicResource Accent.Primary}" />
                                    <Border Height="1" Background="{DynamicResource Border.Strong}" Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding Materials}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Grid.Column="0" Source="{Binding Key, Converter={StaticResource IconKey}}"
                                                           Width="42" Height="42" Margin="0,0,12,0" VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name, Mode=OneWay}" FontSize="15"
                                                                   Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center" />
                                                        <TextBlock Text=" (optional)" FontSize="13" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center"
                                                                   Visibility="{Binding Optional, Converter={StaticResource BoolToVis}}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Quantity, StringFormat='×{0}'}" FontSize="17" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Accent.Primary}" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- multi-item recipes (no dust): declare their count -->
                                    <TextBlock FontSize="14" FontStyle="Italic" Foreground="{DynamicResource Text.Muted}" Margin="0,2,0,0" TextWrapping="Wrap"
                                               Text="{Binding MultiNote, Mode=OneWay}"
                                               Visibility="{Binding MultiNote, Converter={StaticResource StringToVis}}" />

                                    <!-- the LOCKS-FOREVER style warning -->
                                    <Border Margin="0,14,0,0" Padding="12,9" CornerRadius="4" Background="#3A2A10" BorderBrush="#C68A2E" BorderThickness="1"
                                            Visibility="{Binding Warning, Converter={StaticResource StringToVis}}">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#F0C674" TextWrapping="Wrap"
                                                   Text="{Binding Warning, Mode=OneWay}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- ══════ Your Saved Builds ══════
                     Persisted starred builds from %LOCALAPPDATA%\MedicKsMight\favorites.json.
                     Each chip is a LIVE REFERENCE — clicking re-fetches the build from its source so
                     the player gets THIS month's meta, not what was current when they starred it.
                     beta.8: header now shows count + empty state, so first-run users see the affordance
                     instead of an invisible feature (was hidden behind HasFavorites). -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,24,0,0"
                            Visibility="{Binding IsFavTab, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding FavoritesCountLabel}"
                                   FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center" />
                        <TextBlock FontSize="{DynamicResource Type.Body}" FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center">
                            <Run Text="★ Your saved builds" />
                        </TextBlock>
                    </DockPanel>
                    <!-- Empty state — visible when zero favorites; replaces the (previously hidden) chip rail. -->
                    <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Subtle}" BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Card}" Padding="14,10"
                            Visibility="{Binding HasNoFavorites, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Star any build below to pin it here. Picks are live — clicking re-fetches the latest version from its source."
                                   FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" TextWrapping="Wrap" />
                    </Border>
                    <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" Effect="{DynamicResource Elevation.Card}"
                            CornerRadius="{DynamicResource Radius.Card}" Padding="14,12"
                            Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Favorites}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Two-line favorite chip: name on top in class color, provenance
                                         subtitle below ("Maxroll · Endgame · S · added 3d ago"). Whole
                                         chip clicks = re-fetch + load; the ✕ in the corner removes the
                                         favorite without loading it. -->
                                    <Grid Margin="0,0,8,8" Width="220">
                                        <Button Command="{Binding LoadCommand}" ToolTip="{Binding Tip}"
                                                Background="{DynamicResource Surface.Card}" BorderThickness="0"
                                                HorizontalContentAlignment="Stretch"
                                                Padding="10,7" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="fb" Background="{TemplateBinding Background}"
                                                            CornerRadius="{DynamicResource Radius.Card}" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="fb" Property="Background" Value="{DynamicResource Surface.Card.Hover}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{Binding ClassColor}"
                                                           FontSize="{DynamicResource Type.BodySm}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Provenance}" Foreground="{DynamicResource Text.Muted}"
                                                           FontSize="{DynamicResource Type.Caption}" Margin="0,3,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding RemoveCommand}"
                                                Content="✕" FontSize="{DynamicResource Type.Caption}"
                                                Background="Transparent" BorderThickness="0" Padding="0"
                                                Foreground="{DynamicResource Text.Muted}" Cursor="Hand"
                                                MinWidth="18" MinHeight="18"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,4,6,0"
                                                ToolTip="Remove from favorites">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent">
                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   FontSize="{TemplateBinding FontSize}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- ══════ Filter / Show controls ══════
                     Sits between the Favorites strip and the tier-list grid. Class checkboxes
                     are colored with the class's chip color so the row reads as a class palette
                     legend; the two show/hide toggles control chip metadata visibility globally.
                     Browse-only: it only affects the tier grid (June 2026 audit — it used to
                     render orphaned on Compile/Favorites, and would float over Artwork). -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,24,0,0"
                            Visibility="{Binding IsBrowseTab, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True">
                        <!-- Right-side toggles: show class name subtitle / show ★ star button -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Show class name" IsChecked="{Binding ShowClassNames}"
                                      Foreground="{DynamicResource Text.Primary}" Margin="0,0,18,0" VerticalAlignment="Center"
                                      ToolTip="Show '(Sorcerer)' subtitle under each chip's build name" />
                            <CheckBox Content="Show ★ favorite" IsChecked="{Binding ShowFavoriteStars}"
                                      Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center"
                                      ToolTip="Show the star toggle on every tier-list chip" />
                        </StackPanel>
                        <TextBlock Text="Show classes — uncheck to hide a class from every tier list"
                                   FontSize="{DynamicResource Type.Caption}" FontWeight="SemiBold" Foreground="{DynamicResource Text.Muted}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding ClassFilters}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each class checkbox: a thematic Unicode glyph + class name in
                                     the class's chip color. Glyph + color = double cue so the row
                                     reads at a glance (matches the chip-name palette in the grid
                                     below). All on by default; unchecking hides every chip of that
                                     class across all 3 tier sources. -->
                                <CheckBox IsChecked="{Binding IsEnabled}"
                                          Foreground="{Binding ClassColor}"
                                          FontWeight="SemiBold"
                                          Margin="0,0,16,4" VerticalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- v1.0.4 (crest option): full-color premium class crest
                                             (ClassCrests.xaml). Flat-emblem alternative is the
                                             OpacityMask-tinted Rectangle (in git history / ClassEmblems). -->
                                        <Viewbox Width="34" Height="34" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <ContentControl Content="{Binding ClassName, Converter={StaticResource NameToCrest}}" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding ClassName}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ══════ This season's top builds — live community tier lists ══════
                     Three columns: D4Builds (left), Maxroll (middle), Mobalytics (right).
                     Every tier surfaced: S/A/B/C/D plus Mobalytics-only God Tier (top) and Support
                     (utility). Cards + chips at 25% opacity so the warlord background bleeds through. -->
                <StackPanel HorizontalAlignment="Stretch" Margin="0,8,0,0"
                            Visibility="{Binding IsBrowseTab, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="This season's top builds" FontSize="{DynamicResource Type.H2}" FontWeight="Bold"
                                   Foreground="{DynamicResource Accent.Primary}" VerticalAlignment="Center" />
                        <!-- Live re-sync: lists also auto-refresh after 15 min on tab activation, and a
                             re-click of the active tab refreshes just that source. -->
                        <Button VerticalAlignment="Center" Margin="14,0,0,0"
                                Command="{Binding RefreshTierListsCommand}"
                                ToolTip="Re-pull all three tier lists now and re-check your saved builds' tiers (F5). Lists also auto-refresh after 15 minutes.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource LinkButton}">
                                    <Setter Property="Content" Value="⟳ refresh lists" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                                            <Setter Property="Content" Value="⟳ refreshing…" />
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <!-- Attribution (link-out model): rankings belong to the sources; we credit them,
                         link back ("view full list ↗" + right-click any build to open it there), and
                         sell the filter generation. Keeps us clear of redistributing their data as ours. -->
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="680"
                               FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center" Margin="0,2,0,14">
                        <Run Text="Tier rankings courtesy of Maxroll, D4Builds &amp; Mobalytics." />
                        <Run Text="Click any build to make its loot filter, or tick builds to select; while a selection is active, card clicks add/remove and Compile N builds is the only compile action." />
                    </TextBlock>

                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Content="{Binding SuperBuildActionLabel}"
                                Command="{Binding CompileSelectedBuildsCommand}"
                                Padding="18,7"
                                Visibility="{Binding CanCompileSuperBuild, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding SuperBuildSelectionStatus}" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="760" Margin="0,5,0,0"
                                   Foreground="{DynamicResource Danger.Fg}"
                                   Visibility="{Binding SuperBuildSelectionStatus, Converter={StaticResource StringToVis}}" />
                        <TextBlock Text="{Binding SuperBuildAdvisory}" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="760" Margin="0,5,0,0"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   Visibility="{Binding SuperBuildAdvisory, Converter={StaticResource StringToVis}}" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- ── D4Builds (col 1, MIDDLE) ──
                             Moved to middle column 2026-05-28: D4Builds publishes the shortest tier list
                             of the three sources, so its empty bottom band in the middle column lines
                             up with the warlord watermark and lets him surface through naturally. -->
                        <Border Grid.Column="1" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" Effect="{DynamicResource Elevation.Card}"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="14,12" Margin="5,0,5,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding D4BuildsTierUrl}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding D4BuildsUpdatedLabel}"
                                               FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}"
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="D4Builds" FontSize="{DynamicResource Type.H2}" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding D4BuildsTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectD4BuildsTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding D4BuildsTierStatus}" Foreground="{DynamicResource Text.Secondary}" FontSize="{DynamicResource Type.BodySm}"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding D4BuildsTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding D4BuildsTiers}" ItemTemplate="{StaticResource TierRowTemplate}" />
                            </StackPanel>
                        </Border>

                        <!-- ── Maxroll (col 0, LEFT) ── moved from middle to left 2026-05-28 -->
                        <Border Grid.Column="0" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" Effect="{DynamicResource Elevation.Card}"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="14,12" Margin="0,0,5,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding MaxrollTierUrl}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding MaxrollUpdatedLabel}"
                                               FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}"
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Maxroll" FontSize="{DynamicResource Type.H2}" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MaxrollTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectMaxrollTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MaxrollTierStatus}" Foreground="{DynamicResource Text.Secondary}" FontSize="{DynamicResource Type.BodySm}"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding MaxrollTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding MaxrollTiers}" ItemTemplate="{StaticResource TierRowTemplate}" />
                            </StackPanel>
                        </Border>

                        <!-- ── Mobalytics (col 2, NEW) ── God + S/A/B/C + Support -->
                        <Border Grid.Column="2" Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" Effect="{DynamicResource Elevation.Card}"
                                CornerRadius="{DynamicResource Radius.Card}" Padding="14,12" Margin="5,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                            Content="view full list ↗" VerticalAlignment="Center"
                                            Command="{Binding OpenTierUrlCommand}" CommandParameter="{Binding MobalyticsTierUrl}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding MobalyticsUpdatedLabel}"
                                               FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}"
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Mobalytics" FontSize="{DynamicResource Type.H2}" FontWeight="Bold" Foreground="{DynamicResource Accent.Primary}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding MobalyticsTabs}" Margin="0,0,0,6">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource TierTab}" Content="{Binding Label}"
                                                    Command="{Binding DataContext.SelectMobalyticsTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding MobalyticsTierStatus}" Foreground="{DynamicResource Text.Secondary}" FontSize="{DynamicResource Type.BodySm}"
                                           TextWrapping="Wrap" Margin="0,2,0,2"
                                           Visibility="{Binding MobalyticsTierStatus, Converter={StaticResource StringToVis}}" />
                                <ItemsControl ItemsSource="{Binding MobalyticsTiers}" ItemTemplate="{StaticResource TierRowTemplate}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="Tier lists belong to Maxroll.gg, D4Builds.gg, and Mobalytics.gg respectively — shown here with attribution."
                               FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
                </StackPanel>
              </Grid>
            </ScrollViewer>

            <!-- ─── LOADING STATE ─── -->
            <Grid Visibility="{Binding IsLoadingState, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Building your filter…" FontSize="{DynamicResource Type.H1}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="{DynamicResource Type.BodySm}" Foreground="{DynamicResource Text.Muted}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- ─── RESULT STATE ─── -->
            <ScrollViewer Visibility="{Binding IsResultState, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <!-- v1.0.4: quick "make another" at the TOP (mirrors the bottom button) so you
                         don't have to scroll back up to start a different build. -->
                    <Button Content="← Make another filter" Command="{Binding RestartCommand}"
                            Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                            Padding="12,5" FontSize="{DynamicResource Type.BodySm}" Margin="0,0,0,10"
                            ToolTip="Back to the tier lists to pick or paste a different build." />
                    <!-- Result-page header: title on the left, ★ Favorite toggle on the right.
                         The star button only shows when the current build has a URL we can re-fetch
                         (CanFavoriteCurrent — false for pasted builds, true for any URL-based build).
                         Label flips between "★ Favorite this build" and "★ Favorited (click to remove)". -->
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding ToggleFavoriteCurrentCommand}"
                                Visibility="{Binding CanFavoriteCurrent, Converter={StaticResource BoolToVis}}"
                                Background="Transparent" BorderBrush="{DynamicResource Accent.Primary}" BorderThickness="1"
                                Foreground="{Binding IsCurrentFavorited, Converter={StaticResource FavStarBrush}}"
                                Padding="10,4" FontSize="{DynamicResource Type.BodySm}" FontWeight="SemiBold"
                                Cursor="Hand" VerticalAlignment="Center"
                                ToolTip="Save this build to Your Favorites on the landing page">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="{DynamicResource Radius.Control}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock>
                                <Run Text="{Binding IsCurrentFavorited, Converter={StaticResource FavStar}, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="Favorite" />
                            </TextBlock>
                        </Button>
                        <!-- Build name + source-origin pill on the same row.
                             The pill (MAXROLL / D4BUILDS / MOBALYTICS / COMMUNITY) tells the user
                             at a glance which site the build came from — useful when comparing
                             favorites, attribution, or returning to source for updates. Brand-
                             colored via SourceBrush converter. Collapsed pre-load. -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Result-page H1: Display size + ExtraBold + a soft gold glow so the
                                 build title is unmistakably the page's hero (web-app title block). -->
                            <TextBlock Text="{Binding BuildName}"
                                       FontSize="{DynamicResource Type.Display}" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource Accent.Primary}" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#d4af37" BlurRadius="18" ShadowDepth="0" Opacity="0.35" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <Border CornerRadius="{DynamicResource Radius.Pill}" Padding="9,2" Margin="12,3,0,0"
                                    Background="{Binding CurrentSource, Converter={StaticResource SourceBrush}}"
                                    Visibility="{Binding HasCurrentSource, Converter={StaticResource BoolToVis}}"
                                    VerticalAlignment="Center"
                                    ToolTip="Source of this build — click to reload from origin">
                                <TextBlock Text="{Binding CurrentSourceLabel}"
                                           Foreground="White" FontSize="{DynamicResource Type.Caption}" FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Text="{Binding BuildSubtitle}"
                               FontSize="{DynamicResource Type.BodySm}" Foreground="{DynamicResource Text.Secondary}" Margin="0,4,0,4" />
                    <!-- v1.0.4: clickable link to the ORIGINAL build guide on its source site
                         (Maxroll / D4Builds / Mobalytics) — attribution + lets players read the full
                         guide. Only shown when the build came from a URL source (pasted affix lists
                         have none, so CanFavoriteCurrent is false). -->
                    <TextBlock Margin="0,0,0,12" FontSize="{DynamicResource Type.BodySm}"
                               Visibility="{Binding CanFavoriteCurrent, Converter={StaticResource BoolToVis}}">
                        <Hyperlink Command="{Binding OpenBuildGuideCommand}" Foreground="{DynamicResource Accent.Link}"
                                   ToolTip="Open the full build guide on its source site in your browser.">
                            <Run Text="↗ Read the full build guide on " /><Run Text="{Binding CurrentSourceLabel, Mode=OneWay}" />
                        </Hyperlink>
                    </TextBlock>

                    <!-- Armory Mode stays folded during the ordinary one-build flow. It deliberately
                         reuses one text seat for either a supported guide URL or a pasted affix list. -->
                    <Expander Header="＋ Add a second build (Armory Mode)" Margin="0,0,0,12"
                              Foreground="{DynamicResource Accent.Link}">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="One import code can cover two loadouts. Paste a build URL or affix list."
                                       Foreground="{DynamicResource Text.Secondary}" FontSize="{DynamicResource Type.BodySm}"
                                       TextWrapping="Wrap" />
                            <DockPanel Margin="0,6,0,0">
                                <Button DockPanel.Dock="Right" Content="Add build" Command="{Binding AddSecondBuildCommand}"
                                        Style="{StaticResource SecondaryButton}" Padding="12,5" Margin="8,0,0,0" />
                                <TextBox Text="{Binding ArmorySource, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34" VerticalContentAlignment="Center" />
                            </DockPanel>
                            <TextBlock Text="{Binding ArmoryStatus}" Foreground="{DynamicResource Danger.Fg}"
                                       FontSize="{DynamicResource Type.Caption}" Margin="0,5,0,0"
                                       Visibility="{Binding ArmoryStatus, Converter={StaticResource StringToVis}}" />
                        </StackPanel>
                    </Expander>
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Accent.Primary}"
                            BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}" Padding="12,8"
                            Margin="0,0,0,12" Visibility="{Binding HasSecondBuild, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Drop second build" Command="{Binding DropSecondBuildCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="10,0,0,0" />
                            <StackPanel>
                                <TextBlock Text="{Binding ArmoryBuildNames}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Accent.Primary}" />
                                <TextBlock Text="{Binding ArmoryClassNote}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Text.Secondary}" FontSize="{DynamicResource Type.Caption}"
                                           Visibility="{Binding ArmoryClassNote, Converter={StaticResource StringToVis}}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Missing-game-data note (amber): the build references affix/unique ids the
                         local data files can't name — the new-season symptom, fixable by the user
                         via the inline Update link (which re-fetches this build afterwards). Not
                         the same as the dev-only "not yet filterable" list below: that's mapper
                         coverage we fix in code; this is data the app can refresh itself. -->
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Border.Input}"
                            BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                            Padding="12,8" Margin="0,0,0,12"
                            Visibility="{Binding HasMissingDataNote, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource Type.BodySm}"
                                   Foreground="{DynamicResource Text.Secondary}">
                            <Run Text="✓ Filter's ready. " FontWeight="SemiBold" Foreground="#57C46A" /><Run Text="{Binding MissingDataNote, Mode=OneWay}" />
                            <Hyperlink Command="{Binding UpdateGameDataCommand}"
                                       Foreground="{DynamicResource Accent.Link}"
                                       ToolTip="Download the latest affix + unique data, then reload this build automatically.">Update game data</Hyperlink>
                        </TextBlock>
                    </Border>

                    <!-- Favorite build-drift alarm: shown only when this live favorite had a
                         baseline and filter-relevant guide content changed before this compile. -->
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="#D69A2D"
                            BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                            Padding="12,8" Margin="0,0,0,12"
                            Visibility="{Binding HasBuildDriftNote, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BuildDriftNote}" TextWrapping="Wrap"
                                   FontSize="{DynamicResource Type.BodySm}" Foreground="#D69A2D" />
                    </Border>

                    <!-- ═══ THE PAYOFF (v1.0.4): filter title + import code + Copy pulled to the TOP so
                         it's the first thing after the header. Name it, copy it, paste it. All the
                         tuning lives below under "Fine-tune (optional)". ═══ -->
                    <DockPanel LastChildFill="True" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Left" Text="Filter title" VerticalAlignment="Center"
                                   Style="{StaticResource SectionLabel}" Margin="0,0,8,0"
                                   ToolTip="Becomes the filter's name in Diablo 4 when imported. D4 drops names longer than 24 chars." />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TitleLengthNote}"
                                   FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBox Text="{Binding FilterTitle, UpdateSourceTrigger=PropertyChanged}"
                                 LostFocus="FilterTitle_LostFocus"
                                 MaxLength="24" Height="34" FontSize="{DynamicResource Type.Body}" FontFamily="{DynamicResource Font.Sans}" />
                    </DockPanel>
                    <TextBlock Text="Copy your import code" Style="{StaticResource SectionLabel}" Margin="0,12,0,4" />
                    <Border BorderBrush="{DynamicResource Accent.Primary}" BorderThickness="3,0,0,0"
                            Background="{DynamicResource Surface.Inset}" CornerRadius="{DynamicResource Radius.Control}" Padding="8">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Content="Save PNG…" Click="SaveWitnessCard_Click"
                                        IsEnabled="{Binding CanShareWitnessCard}" Height="40" Padding="12,0"
                                        Style="{StaticResource SecondaryButton}"
                                        ToolTip="{Binding WitnessCardBlockReason}" ToolTipService.ShowOnDisabled="True" />
                                <Button Content="Share card" Click="ShareWitnessCard_Click"
                                        IsEnabled="{Binding CanShareWitnessCard}" Height="40" Padding="14,0" Margin="6,0,0,0"
                                        FontWeight="SemiBold" ToolTip="{Binding WitnessCardBlockReason}"
                                        ToolTipService.ShowOnDisabled="True" />
                                <Button Content="{Binding CopyButtonText}" Command="{Binding CopyCodeCommand}"
                                        Width="110" Height="40" Margin="6,0,0,0" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBox Text="{Binding ImportCode, Mode=OneWay}"
                                     IsReadOnly="True" Height="40" FontSize="{DynamicResource Type.Caption}"
                                     FontFamily="{DynamicResource Font.Mono}"
                                     TextWrapping="NoWrap" BorderThickness="0"
                                     Background="Transparent"
                                     HorizontalScrollBarVisibility="Hidden"
                                     VerticalContentAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <!-- Persistent copy confirmation (v1.0.4): the intended success line was never wired
                         into the result state; bind it here so Copy gives lasting feedback, not a blink. -->
                    <TextBlock Text="{Binding CopyConfirmation}" TextWrapping="Wrap" Margin="2,6,0,0"
                               FontSize="{DynamicResource Type.BodySm}" FontWeight="SemiBold" Foreground="#57C46A"
                               Visibility="{Binding CopyConfirmation, Converter={StaticResource StringToVis}}" />
                    <TextBlock Text="{Binding WitnessCardConfirmation}" TextWrapping="Wrap" Margin="2,6,0,0"
                               FontSize="{DynamicResource Type.BodySm}" FontWeight="SemiBold" Foreground="#57C46A"
                               Visibility="{Binding WitnessCardConfirmation, Converter={StaticResource StringToVis}}" />
                    <DockPanel LastChildFill="True" Margin="0,6,0,0">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding FilterInfo}" Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center" FontSize="{DynamicResource Type.BodySm}" FontFamily="{DynamicResource Font.Mono}" />
                        <Expander Header="▾ Show full code" Foreground="{DynamicResource Text.Muted}" FontSize="{DynamicResource Type.Caption}"
                                  HorizontalAlignment="Left">
                            <TextBox Text="{Binding ImportCode, Mode=OneWay}"
                                     IsReadOnly="True" MinHeight="100" MaxHeight="200" TextWrapping="Wrap"
                                     FontFamily="{DynamicResource Font.Mono}"
                                     VerticalScrollBarVisibility="Auto" FontSize="{DynamicResource Type.Caption}" Margin="0,6,0,0" />
                        </Expander>
                    </DockPanel>
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Accent.Primary}" BorderThickness="3,1,1,1"
                            CornerRadius="{DynamicResource Radius.Control}" Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding HasAutoFitNote, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding AutoFitNote}" TextWrapping="Wrap" FontSize="{DynamicResource Type.BodySm}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Accent.Primary}" />
                    </Border>
                    <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Accent.Primary}" BorderThickness="3,1,1,1"
                            CornerRadius="{DynamicResource Radius.Control}" Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding SuperBuildAdvisory, Converter={StaticResource StringToVis}}">
                        <StackPanel>
                            <TextBlock Text="ADVISORY" FontSize="{DynamicResource Type.Caption}" FontWeight="Bold"
                                       Foreground="{DynamicResource Accent.Primary}" Margin="0,0,0,3" />
                            <TextBlock Text="{Binding SuperBuildAdvisory}" TextWrapping="Wrap"
                                       FontSize="{DynamicResource Type.BodySm}" Foreground="{DynamicResource Accent.Primary}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource Danger.Bg}" BorderBrush="{DynamicResource Danger.Border}" BorderThickness="1"
                            CornerRadius="{DynamicResource Radius.Control}" Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding HasCapWarning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding CapWarning}" TextWrapping="Wrap" FontSize="{DynamicResource Type.BodySm}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Danger.Fg}" />
                    </Border>
                    <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource Type.Caption}" Margin="0,8,0,12"
                               Foreground="{DynamicResource Text.Muted}">
                        <Run Text="ℹ Changed an option below? Copy the new code and re-import; in-game filters don't auto-update." />
                    </TextBlock>

                    <TextBlock Text="Fine-tune (optional)" Style="{StaticResource SectionLabel}" Margin="0,4,0,4"
                               ToolTip="The code above already matches this build. Everything below is optional tweaking." />

                    <!-- Variant picker — uncheck a variant to drop it from the combined pool.
                         v1.0.5: promoted to the true card recipe (matches the tier columns). -->
                    <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" Effect="{DynamicResource Elevation.Card}"
                            CornerRadius="{DynamicResource Radius.Card}" Padding="{DynamicResource Pad.Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Variants included (uncheck to narrow the filter — recompiles live)"
                                       Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding VariantGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,8">
                                            <DockPanel Margin="0,0,0,2" LastChildFill="True">
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <TextBlock Text="Priority" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource Text.Muted}" Margin="12,0,5,0" />
                                                    <ComboBox Width="52"
                                                              ItemsSource="{Binding PriorityChoices}"
                                                              SelectedItem="{Binding Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ToolTip="Priority 1 is protected. Choosing an occupied priority swaps the two builds." />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Header}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Accent.Primary}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Variants}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                                  Content="{Binding Label}"
                                                                  Margin="0,2,22,2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: affix pool. beta.8.3: 3-column grid layout instead of a tall single
                             column — 27 affixes / 3 cols = 9 rows tall instead of 27. Pairs with the
                             right Legend tab going 2-col below. Result: both boxes ~200px tall, the
                             entire result page fits without scroll at 1080p so users don't scroll to
                             reach the Copy button. -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Top">
                            <TextBlock Text="Filterable affixes — these drive the gold / silver match"
                                       Style="{StaticResource SectionLabel}" />
                            <ListBox ItemsSource="{Binding PoolLines}" Height="172"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- Right: uniques / mythics / pending / color legend in a TabControl.
                             beta.8 polish: was 4 stacked sections + 4 fixed-height ListBoxes burning
                             ~360px of vertical with lots of dead air when only 1-2 categories were
                             populated.
                             beta.8.2: fixed Height 264 (instead of MaxHeight=300) so the right box is
                             exactly the same height as the left column (240 ListBox + 24 header label
                             = 264). Filter Options below snaps up since no asymmetric row stretch. -->
                        <!-- Right side: Uniques | Legend side-by-side. (S14: the separate Mythics panel
                             was retired — "mythic" is now a quality any unique can have/upgrade to, not
                             a fixed roster, so a build's uniques are shown as one list.) -->
                        <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- v3: dropped the gold-underlined "tab" headers — the colored SectionLabel
                                 below them was already doing the panel-title work, the tab pseudo-headers
                                 were just visual noise. Each panel's section label IS the title now. -->

                            <!-- Uniques panel -->
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Style="{StaticResource SectionLabel}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}">
                                    <Run Text="Build uniques → " /><Run Text="purple" Foreground="#a020f0" />
                                </TextBlock>
                                <ListBox ItemsSource="{Binding UniquePurpleLines}" MinHeight="80" MaxHeight="160"
                                         Visibility="{Binding HasPurple, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="Build uniques — name match only"
                                           Style="{StaticResource SectionLabel}" Margin="0,10,0,4"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />
                                <ListBox ItemsSource="{Binding UniquePendingLines}" MinHeight="50" MaxHeight="100"
                                         Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="No uniques in this build."
                                           Foreground="{DynamicResource Text.Muted}" FontSize="{DynamicResource Type.Caption}" FontStyle="Italic" Margin="0,4,0,0"
                                           Visibility="{Binding HasNoUniques, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>

                            <!-- Legend panel — title now matches the other panels' SectionLabel sizing. -->
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Legend — what the colors mean"
                                           Style="{StaticResource SectionLabel}"
                                           TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding VariantGroups}" Margin="0,0,0,6">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,5"
                                                        Visibility="{Binding HasColorPickers, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding Header}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Accent.Primary}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Grid Margin="0,2,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,3,0">
                                                        <TextBlock Text="Chase color" FontSize="{DynamicResource Type.Caption}"
                                                                   Foreground="{DynamicResource Text.Muted}" />
                                                        <ComboBox ItemsSource="{Binding Palette}" IsEnabled="{Binding TierColorsEnabled}"
                                                                  SelectedItem="{Binding ChaseColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Width="12" Height="12" Background="{Binding Hex}"
                                                                                BorderBrush="#777777" BorderThickness="1" Margin="0,0,5,0" />
                                                                        <TextBlock Text="{Binding FullName}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="3,0,0,0">
                                                        <TextBlock Text="Keeper color" FontSize="{DynamicResource Type.Caption}"
                                                                   Foreground="{DynamicResource Text.Muted}" />
                                                        <ComboBox ItemsSource="{Binding Palette}" IsEnabled="{Binding TierColorsEnabled}"
                                                                  SelectedItem="{Binding KeeperColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Width="12" Height="12" Background="{Binding Hex}"
                                                                                BorderBrush="#777777" BorderThickness="1" Margin="0,0,5,0" />
                                                                        <TextBlock Text="{Binding FullName}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding TierEmissionNote}" TextWrapping="Wrap"
                                                           FontSize="{DynamicResource Type.Caption}" FontStyle="Italic"
                                                           Foreground="#E0A030" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Background="{DynamicResource Surface.Inset}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                                        CornerRadius="{DynamicResource Radius.Control}" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap"><Run Foreground="#a020f0" Text="● Purple" /><Run Text=": build uniques" /></TextBlock>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap" Text="{Binding BuildTierLegend}" />
                                        <TextBlock Margin="0,1" TextWrapping="Wrap"><Run Foreground="#ff8c00" Text="● Orange" /><Run Foreground="#00ffff" Text="/Cyan" /><Run Text=": IP 900/850" /></TextBlock>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap"><Run Foreground="#2251e8" Text="● Blue" /><Run Text=": Greater Affix items" /></TextBlock>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap"><Run Foreground="#00c800" Text="● Green" /><Run Text=": Charms &amp; Seals" /></TextBlock>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap"><Run Foreground="#ffffff" Text="● White" /><Run Text=": Codex upgrades" /></TextBlock>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap" Foreground="{DynamicResource Text.Muted}"><Run Text="◌ Hidden" /><Run Text=": everything else" /></TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Filter options (v1.0.3): now four collapsible groups inside one card. Each
                         header row is a ToggleButton (chevron ▾/▸ + label) that shows/hides its group.
                         "Filter options" + "Charm sets" reopen on every app launch (state not saved);
                         the two big unique lists remember their state and reopen only on a new build. -->
                    <Border Background="{DynamicResource Surface.Card}" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" Effect="{DynamicResource Elevation.Card}"
                            CornerRadius="{DynamicResource Radius.Card}" Padding="{DynamicResource Pad.Card}">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding FilterOptionsExpanded}" Style="{StaticResource SectionToggle}" Margin="0,0,0,2"
                                          ToolTip="Each toggle is a rule the filter emits. Red = 3+ affix legendaries, Pink = 3+ affix rares. Mythics are never touched.">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource SectionChevron}" />
                                    <TextBlock Text="Filter options" Style="{StaticResource SectionLabel}" Margin="0" />
                                    <TextBlock Text="  good defaults are set · click to fine-tune" VerticalAlignment="Center"
                                               FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" />
                                </StackPanel>
                            </ToggleButton>
                            <StackPanel ClipToBounds="True" b:Reveal.IsOpen="{Binding FilterOptionsExpanded}">
                            <!-- ── Primary matching choice: per-slot mode + the two color-coded build-affix tiers ── -->
                            <CheckBox Content="Precise per-slot rules (recommended)" IsChecked="{Binding OptPerSlot}"
                                      Foreground="{Binding OptPerSlot, Converter={StaticResource ActiveText}}" Margin="0,0,0,6"
                                      ToolTip="ON: each gear slot gets its own rule, scoped to that item type (a boots rule only matches boots). OFF: matches by affix COUNT across ALL slots, which can show false 'keeps' (e.g. boots that rolled chest/ring stats)." />
                            <!-- v1.0.2: Leveling mode (off by default; strict endgame is the standard). Adds a
                                 silver 2+ affix-rare tier and forces coarse combined rules to fit the 25-cap. -->
                            <CheckBox Content="Leveling — also show 2+ affix rares (Silver)" IsChecked="{Binding OptLeveling}"
                                      IsEnabled="{Binding MultiBuildLevelingEnabled}"
                                      Foreground="{Binding OptLeveling, Converter={StaticResource ActiveText}}" Margin="0,0,0,2"
                                      ToolTip="OFF (default): endgame — only 3+ affix items (Red legendaries / Pink rares). ON: adds a Silver tier for 2+ affix rares so you can gear up while leveling. To fit the 25-rule limit it uses coarse combined rules (not per-slot), so it shows a lot — best with a leveling build loaded, not recommended for endgame." />
                            <TextBlock Text="Leveling shows a LOT (coarse, combined rules, not per-slot). Load a leveling build before turning it on; not recommended for endgame."
                                       FontSize="{DynamicResource Type.Caption}" Foreground="#E0A030" FontStyle="Italic" TextWrapping="Wrap"
                                       Margin="0,0,0,6" Visibility="{Binding OptLeveling, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="Leveling is unavailable for Super Builds: multi-build hunters use fixed 3+ endgame tiers only. A rare with only 2 wanted affixes is not rescued."
                                       FontSize="{DynamicResource Type.Caption}" Foreground="#E0A030" FontStyle="Italic" TextWrapping="Wrap"
                                       Margin="0,0,0,6" Visibility="{Binding MultiBuildTierLayoutFixed, Converter={StaticResource BoolToVis}}" />
                            <!-- beta.8.1: every row uses a 2-col Grid (32px chip slot | checkbox+label)
                                 so every checkbox locks to x=32 regardless of how many chips a row
                                 carries. Fixes the Item Power row pushing right because it has 2 chips. -->
                            <TextBlock Text="Super Build layout is fixed: every build keeps its 3+ legendary and 3+ rare tiers."
                                       FontSize="{DynamicResource Type.Caption}" Foreground="#E0A030" FontStyle="Italic"
                                       TextWrapping="Wrap" Margin="0,0,0,4"
                                       Visibility="{Binding MultiBuildTierLayoutFixed, Converter={StaticResource BoolToVis}}" />
                            <UniformGrid Columns="2" IsEnabled="{Binding MultiBuildTierControlsEnabled}">
                                <!-- 3+ → Red (chase). v1.0.2: rarity sub-toggles refine the mask INSIDE
                                     this rule (rare/leg/ancestral) — regenerate the code as the
                                     character progresses; the rule count never changes. -->
                                <StackPanel>
                                    <Grid Margin="0,3,14,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Background="{Binding OptGoldTier, Converter={StaticResource ActiveColor}, ConverterParameter=#DC0000}" />
                                        <CheckBox Grid.Column="1" Content="3+ affix legendaries → Red (best items)" IsChecked="{Binding OptGoldTier}"
                                                  Foreground="{Binding OptGoldTier, Converter={StaticResource ActiveText}}" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="32,0,0,0" IsEnabled="{Binding OptGoldTier}">
                                        <CheckBox Content="Show rares" IsChecked="{Binding OptRedRares}" FontSize="{DynamicResource Type.Caption}" Margin="0,0,12,0"
                                                  Foreground="{Binding OptRedRares, Converter={StaticResource ActiveText}}" />
                                        <CheckBox Content="Show legendaries" IsChecked="{Binding OptRedLegendaries}" FontSize="{DynamicResource Type.Caption}" Margin="0,0,12,0"
                                                  Foreground="{Binding OptRedLegendaries, Converter={StaticResource ActiveText}}" />
                                        <CheckBox Content="Ancestral only" IsChecked="{Binding OptRedAncestralOnly}" FontSize="{DynamicResource Type.Caption}"
                                                  Foreground="{Binding OptRedAncestralOnly, Converter={StaticResource ActiveText}}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding RedTierSummary, Mode=OneWay}" FontSize="{DynamicResource Type.Caption}"
                                               Foreground="{DynamicResource Text.Muted}" FontStyle="Italic" Margin="32,0,14,3" TextWrapping="Wrap" />
                                </StackPanel>
                                <!-- 2+ → Pink (keeper) + its own rarity sub-toggles (e.g. late-game:
                                     Rares off, Legendaries on — "at least it rolls four affixes"). -->
                                <StackPanel>
                                    <Grid Margin="0,3,14,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Background="{Binding OptSilverTier, Converter={StaticResource ActiveColor}, ConverterParameter=#FF69B4}" />
                                        <CheckBox Grid.Column="1" Content="3+ affix rares → Pink (keeper)" IsChecked="{Binding OptSilverTier}"
                                                  Foreground="{Binding OptSilverTier, Converter={StaticResource ActiveText}}" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="32,0,0,0" IsEnabled="{Binding OptSilverTier}">
                                        <CheckBox Content="Show rares" IsChecked="{Binding OptPinkRares}" FontSize="{DynamicResource Type.Caption}" Margin="0,0,12,0"
                                                  Foreground="{Binding OptPinkRares, Converter={StaticResource ActiveText}}" />
                                        <CheckBox Content="Show legendaries" IsChecked="{Binding OptPinkLegendaries}" FontSize="{DynamicResource Type.Caption}" Margin="0,0,12,0"
                                                  Foreground="{Binding OptPinkLegendaries, Converter={StaticResource ActiveText}}" />
                                        <CheckBox Content="Ancestral only" IsChecked="{Binding OptPinkAncestralOnly}" FontSize="{DynamicResource Type.Caption}"
                                                  Foreground="{Binding OptPinkAncestralOnly, Converter={StaticResource ActiveText}}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding PinkTierSummary, Mode=OneWay}" FontSize="{DynamicResource Type.Caption}"
                                               Foreground="{DynamicResource Text.Muted}" FontStyle="Italic" Margin="32,0,14,3" TextWrapping="Wrap" />
                                </StackPanel>
                            </UniformGrid>

                            <Border Height="1" Background="{DynamicResource Border.Subtle}" Margin="0,10,0,10" />

                            <!-- ── Secondary tiers (each marker shows its in-game highlight color, grays when off) ──
                                 beta.8.4: 2-col → 4-col. 8 toggles → 2 rows × 4 cols instead of 4 rows × 2.
                                 Saves ~65px vertical. Each cell at 1600px window = ~290px — fits the longest
                                 label "Item power 900/850 → Orange/Cyan" (chip slot + checkbox + label ≈ 210px). -->
                            <UniformGrid Columns="4">
                                <!-- Build uniques → purple -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptBuildUniques, Converter={StaticResource ActiveColor}, ConverterParameter=#A020F0}" />
                                    <CheckBox Grid.Column="1" Content="Build uniques → Purple" IsChecked="{Binding OptBuildUniques}"
                                              Foreground="{Binding OptBuildUniques, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- Greater Affixes → blue -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptGreaterAffixes, Converter={StaticResource ActiveColor}, ConverterParameter=#2251E8}" />
                                    <CheckBox Grid.Column="1" Content="Greater Affixes → Blue" IsChecked="{Binding OptGreaterAffixes}"
                                              Foreground="{Binding OptGreaterAffixes, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- Item-power tiers → orange + cyan (TWO chips in the same fixed 32px slot,
                                     side-by-side centered, so the checkbox still locks to x=32) -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="13" Height="14" CornerRadius="{DynamicResource Radius.Control}" Margin="0,0,2,0"
                                                Background="{Binding OptItemPowerTiers, Converter={StaticResource ActiveColor}, ConverterParameter=#FF8C00}" />
                                        <Border Width="13" Height="14" CornerRadius="{DynamicResource Radius.Control}" Margin="2,0,0,0"
                                                Background="{Binding OptItemPowerTiers, Converter={StaticResource ActiveColor}, ConverterParameter=#00FFFF}" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Content="Item power 900/850 → Orange/Cyan"
                                              IsChecked="{Binding OptItemPowerTiers}"
                                              Foreground="{Binding OptItemPowerTiers, Converter={StaticResource ActiveText}}"
                                              ToolTip="Gearing aid — noisy at endgame (nearly every drop is max item power, so the highlight loses signal)." />
                                </Grid>
                                <!-- Charms &amp; Seals (Ancestral) → red — emitted ABOVE the green rule
                                     so ancestral charms/seals win priority. Lets players turn off the
                                     basic green noise while keeping rare ancestrals visible. -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptCharmsSealsAncestral, Converter={StaticResource ActiveColor}, ConverterParameter=#DC0000}" />
                                    <CheckBox Grid.Column="1" Content="Charms &amp; Seals (Ancestral) → Red" IsChecked="{Binding OptCharmsSealsAncestral}"
                                              Foreground="{Binding OptCharmsSealsAncestral, Converter={StaticResource ActiveText}}"
                                              ToolTip="Highlight ancestral-tier charms and seals in red, above the basic green rule. Lets you turn off the basic-charm green flood without losing rare ancestrals." />
                                </Grid>
                                <!-- Charms &amp; Seals → green (basic; sits below the ancestral red rule) -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptCharmsSeals, Converter={StaticResource ActiveColor}, ConverterParameter=#00C800}" />
                                    <CheckBox Grid.Column="1" Content="Charms &amp; Seals → Green" IsChecked="{Binding OptCharmsSeals}"
                                              Foreground="{Binding OptCharmsSeals, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- Codex upgrades → white -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptCodex, Converter={StaticResource ActiveColor}, ConverterParameter=#FFFFFF}" />
                                    <CheckBox Grid.Column="1" Content="Codex upgrades → White" IsChecked="{Binding OptCodex}"
                                              Foreground="{Binding OptCodex, Converter={StaticResource ActiveText}}" />
                                </Grid>
                                <!-- ── Behavioral toggles: no color emitted, so each gets the same hollow
                                     outline chip (#6b625a). Visually consistent — "this row has no chip
                                     color of its own; it changes filter behavior" reads the same for all 3. -->
                                <!-- Hide everything else -->
                                <!-- Cube bases (v1.0.2): 2-on-build-affix MAGIC items = Horadric Add-Affix fodder -->
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding OptCubeBases, Converter={StaticResource ActiveColor}, ConverterParameter=#FFD700}" />
                                    <CheckBox Grid.Column="1" Content="Cube bases (GA blues) → Gold" IsChecked="{Binding OptCubeBases}"
                                              Foreground="{Binding OptCubeBases, Converter={StaticResource ActiveText}}"
                                              ToolTip="For the crafting crowd: Magic items with BOTH affixes on your build AND at least one Greater Affix — the blues actually worth stopping for as Horadric Cube bases. Off by default (speedfarmers, keep blasting). If gold never fires for you, GA blues may simply not drop — tell Medick." />
                                </Grid>
                                <Grid Margin="0,3,14,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="14" Height="14" CornerRadius="{DynamicResource Radius.Control}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="Transparent" BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1" />
                                    <CheckBox Grid.Column="1" Content="Hide everything else" IsChecked="{Binding OptHideRest}"
                                              Foreground="{Binding OptHideRest, Converter={StaticResource ActiveText}}"
                                              ToolTip="Hide commons/magics/rares/legendaries the rules above didn't match. Uniques and mythics always drop." />
                                </Grid>
                                <!-- v1.0.2: the "Strict" preset checkbox was removed — strict IS the
                                     standard now (Red 3+ legendaries / Pink 3+ rares are the defaults).
                                     The looser 2+ rares moved to the opt-in "Leveling" checkbox up by
                                     "Precise per-slot rules." -->
                            </UniformGrid>
                            </StackPanel>

                            <!-- ── Charm sets (v1.0.1 per-class talisman checkboxes; v1.0.3 collapsible,
                                 reopens each app launch). Build's sets come pre-checked; unchecked sets
                                 are hidden. The whole group hides until a build offers sets. -->
                            <StackPanel Visibility="{Binding HasTalismanSetOptions, Converter={StaticResource BoolToVis}}">
                                <Border Height="1" Background="{DynamicResource Border.Subtle}" Margin="0,10,0,10" />
                                <DockPanel Margin="0,0,0,4" LastChildFill="True" IsEnabled="{Binding CharmSetSelectionEnabled}">
                                    <Button DockPanel.Dock="Right" Content="Unselect all" Padding="8,2" Margin="6,0,0,0" FontSize="12"
                                            Command="{Binding UncheckAllCharmSetsCommand}" />
                                    <Button DockPanel.Dock="Right" Content="Select all" Padding="8,2" FontSize="12"
                                            Command="{Binding CheckAllCharmSetsCommand}" />
                                    <Button DockPanel.Dock="Right" Content="Re-check from current variants" Padding="8,2" Margin="6,0,0,0" FontSize="12"
                                            Command="{Binding RecheckCharmSetsCommand}"
                                            ToolTip="pulls from the currently highlighted variants that are open in the menu on screen at the moment" />
                                    <ToggleButton IsChecked="{Binding CharmSetsExpanded}" Style="{StaticResource SectionToggle}"
                                                  ToolTip="All of your class's talisman sets plus the generic small sets. The sets your build calls for come pre-checked. Checked sets pack into one green rule (plus one ancestral-red rule); unchecked sets are hidden by the filter.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource SectionChevron}" />
                                            <TextBlock Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" Text="Charm sets" />
                                            <TextBlock Text="  checked = shown · unchecked = hidden" VerticalAlignment="Center"
                                                       FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" />
                                        </StackPanel>
                                    </ToggleButton>
                                </DockPanel>
                                <StackPanel ClipToBounds="True" b:Reveal.IsOpen="{Binding CharmSetsExpanded}">
                                <!-- v1.0.4: when a build carries no charm-set data (pasted affix lists,
                                     or a guide that skips charms) we show ALL the class's sets so charms
                                     aren't hidden; this note explains it. v1.0.5: all three sites now
                                     detect, so this fires mainly for pasted builds. -->
                                <TextBlock FontSize="{DynamicResource Type.Caption}" FontStyle="Italic"
                                           Foreground="{DynamicResource Text.Muted}" TextWrapping="Wrap" Margin="0,0,0,6"
                                           Visibility="{Binding CharmSetsUndetected, Converter={StaticResource BoolToVis}}"
                                           Text="{Binding CharmSetSafetyNote}" />
                                <ItemsControl ItemsSource="{Binding TalismanSetOptions}" IsEnabled="{Binding CharmSetSelectionEnabled}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                                      Margin="0,3,18,3"
                                                      Foreground="{Binding IsChecked, Converter={StaticResource ActiveText}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </StackPanel>
                            </StackPanel>

                            <!-- ── Unique charms (v1.0.2 show-list; v1.0.3 collapsible group that
                                 remembers its state and reopens only on a new/different build). Every
                                 S14 unique charm, ALL pre-checked; uncheck any to hide it. ~110, scrolls. -->
                            <StackPanel Visibility="{Binding HasUniqueCharmOptions, Converter={StaticResource BoolToVis}}">
                                <Border Height="1" Background="{DynamicResource Border.Subtle}" Margin="0,10,0,10" />
                                <DockPanel Margin="0,0,0,4" LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Content="Unselect all" Padding="8,2" Margin="6,0,0,0" FontSize="12"
                                            Command="{Binding UncheckAllUniqueCharmsCommand}" />
                                    <Button DockPanel.Dock="Right" Content="Select all" Padding="8,2" FontSize="12"
                                            Command="{Binding CheckAllUniqueCharmsCommand}" />
                                    <ToggleButton IsChecked="{Binding UniqueCharmsExpanded}" Style="{StaticResource SectionToggle}"
                                                  ToolTip="Every S14 unique charm. All checked = they all drop visible in their natural color (your build's uniques still show purple). Uncheck the ones you don't want to hide them. Seals aren't listed here — they stay hidden.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource SectionChevron}" />
                                            <TextBlock Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" Text="Unique charms" />
                                            <TextBlock Text="{Binding UniqueCharmsSummary}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                       FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" />
                                        </StackPanel>
                                    </ToggleButton>
                                </DockPanel>
                                <StackPanel ClipToBounds="True" b:Reveal.IsOpen="{Binding UniqueCharmsExpanded}">
                                <TextBlock FontSize="12" FontStyle="Italic" Foreground="{DynamicResource Text.Muted}"
                                           TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="Checked charms drop on the ground in their normal color. Unchecked charms are hidden by the 'Hide the rest' rule at the bottom. Your build's own unique charms always show purple, from the 'Build Uniques' rule near the top of the filter." />
                                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding UniqueCharmOptions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                                          Margin="0,3,18,3" Width="210"
                                                          Foreground="{Binding IsChecked, Converter={StaticResource ActiveText}}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                </StackPanel>
                            </StackPanel>

                            <!-- ── Uniques (v1.0.2 hide-list; v1.0.3 collapsible group that remembers
                                 its state and reopens only on a new/different build). Every regular
                                 unique, ALL pre-checked; unchecking one adds it to "Hide Uniques". ~329. -->
                            <StackPanel Visibility="{Binding HasUniqueItemOptions, Converter={StaticResource BoolToVis}}">
                                <Border Height="1" Background="{DynamicResource Border.Subtle}" Margin="0,10,0,10" />
                                <DockPanel Margin="0,0,0,4" LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Content="Unselect all" Padding="8,2" Margin="6,0,0,0" FontSize="12"
                                            Command="{Binding UncheckAllUniquesCommand}" />
                                    <Button DockPanel.Dock="Right" Content="Select all" Padding="8,2" FontSize="12"
                                            Command="{Binding CheckAllUniquesCommand}" />
                                    <ToggleButton IsChecked="{Binding UniquesExpanded}" Style="{StaticResource SectionToggle}"
                                                  ToolTip="Every regular unique in the game. All checked = they all drop as normal. Uncheck ones you never want to see and they get hidden. Your build's own uniques still show purple no matter what, and a Mythic version of any unique is never hidden.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource SectionChevron}" />
                                            <TextBlock Style="{StaticResource SectionLabel}" Margin="0" VerticalAlignment="Center" Text="Uniques" />
                                            <TextBlock Text="{Binding UniquesSummary}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                       FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" />
                                        </StackPanel>
                                    </ToggleButton>
                                </DockPanel>
                                <StackPanel ClipToBounds="True" b:Reveal.IsOpen="{Binding UniquesExpanded}">
                                <TextBlock FontSize="12" FontStyle="Italic" Foreground="{DynamicResource Text.Muted}"
                                           TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="Checked uniques drop as normal. Unchecked ones are hidden by a 'Hide Uniques' rule. Your build's own uniques always show purple, and Mythic versions are never hidden." />
                                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding UniqueItemOptions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                                          Margin="0,3,18,3" Width="210"
                                                          Foreground="{Binding IsChecked, Converter={StaticResource ActiveText}}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                </StackPanel>
                            </StackPanel>
                            <!-- beta.8.3: the 2-paragraph explainer here moved into tooltips on
                                 "Filter options" header + "Precise per-slot rules" checkbox above —
                                 frees ~50px of vertical so the Copy button fits above the fold. -->
                        </StackPanel>
                    </Border>

                    <!-- (Filter title + import code + Copy + cap/auto-fit notes were moved to the TOP
                         of this page in v1.0.4 — payoff first. See "THE PAYOFF" block above.) -->
                    <!-- How to import (beta.8: collapsed into an Expander since this is read-once
                         reference content — recovers ~140px of viewport from the read-only banner). -->
                    <Expander Header="? How to import into Diablo 4" Foreground="{DynamicResource Accent.Primary}" FontSize="{DynamicResource Type.BodySm}"
                              FontWeight="SemiBold" Margin="0,14,0,0">
                        <Border Background="{DynamicResource Surface.Panel}" BorderBrush="{DynamicResource Border.Input}" BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Control}" Padding="14,12" Margin="0,6,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource Type.BodySm}" Foreground="{DynamicResource Text.Primary}" LineHeight="20">
                                <Run Text="1. In Diablo 4, open the Character menu and go to the Loot Filter tab." /><LineBreak />
                                <Run Text="2. Click Import / Export, then Import." /><LineBreak />
                                <Run Text="3. Paste the code above and confirm. The filter applies immediately." /><LineBreak />
                                <Run Text="Filters sync across platforms through your Battle.net account (25-rule cap; rules apply top-down, first match wins)." />
                            </TextBlock>
                        </Border>
                    </Expander>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="← Make another filter"
                                Command="{Binding RestartCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="220" Height="44" FontSize="{DynamicResource Type.Body}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ══════ ARTWORK MODE (gallery tab) ══════ Same warlord art, FULL strength,
                 BOTTOM-anchored: a UniformToFill cover-crop whose clip eats the TOP of the
                 composition instead of the bottom — the sword lives at the bottom edge (Medick's
                 call; replaced a scrollable pan, beta.9). WPF's Image element always anchors
                 top-left, hence an ImageBrush, which exposes AlignmentY. -->
            <Rectangle IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="{Binding IsArtworkTab, Converter={StaticResource BoolToVis}}">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="Assets/hero.jpg" Stretch="UniformToFill"
                                AlignmentX="Center" AlignmentY="Bottom" />
                </Rectangle.Fill>
            </Rectangle>

        </Grid>

        <!-- ════════════════════════ FOOTER ════════════════════════ -->
        <Border Grid.Row="3" Background="{DynamicResource Surface.Panel}" Padding="12,6" CornerRadius="{DynamicResource Radius.Control}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center">
                    <Run Text="{Binding AppVersionLabel, Mode=OneWay}" />
                    <Run Text="  •  " />
                    <Run Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#8c8" />
                </TextBlock>

                <!-- CC BY 3.0 attribution for the licensed class icons is REQUIRED — keep this line.
                     Lives in the STAR column (an Auto column measures infinite → never wraps, just
                     clips); wraps to two lines at narrow widths so the credit and the trademark
                     line both stay readable. -->
                <TextBlock Grid.Column="1" Margin="16,0,0,0" FontSize="{DynamicResource Type.Caption}" Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Right">
                    Class icons: Lorc and Delapouite, game-icons.net (CC BY 3.0)  •  Not affiliated with or endorsed by Blizzard Entertainment. Diablo is a trademark of Blizzard Entertainment, Inc.
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
